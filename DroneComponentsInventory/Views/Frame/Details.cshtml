@model DroneComponentsInventory.Models.FrameComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Frame Details</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/frames.css" />
</head>

<body class="is-preload">

    <div class="frames-panel">

        <h2>@Model.Manufacturer @Model.Model</h2>

        <dl class="frames-meta">
            <dt>Wheelbase</dt>
            <dd>@(Model.WheelbaseMm?.ToString() + " mm" ?? "—")</dd>

            <dt>Max Prop Size</dt>
            <dd>@(Model.MaxPropInch?.ToString() + "\"" ?? "—")</dd>

            <dt>Geometry</dt>
            <dd>@(Model.Geometry ?? "—")</dd>

            <dt>Material</dt>
            <dd>@(Model.Material ?? "—")</dd>

            <dt>Weight</dt>
            <dd>@(Model.WeightG?.ToString() + " g" ?? "—")</dd>

            <dt>Arm Thickness</dt>
            <dd>@(Model.ArmThicknessMm?.ToString() + " mm" ?? "—")</dd>

            <dt>Motor Mount Pattern</dt>
            <dd>@(Model.MotorMountPattern ?? "—")</dd>

            <dt>FC Mount Pattern</dt>
            <dd>@(Model.FcMountPattern ?? "—")</dd>

            <dt>Max Stack Height</dt>
            <dd>@(Model.MaxStackHeightMm?.ToString() + " mm" ?? "—")</dd>

            <dt>Price</dt>
            <dd>@(Model.Price.HasValue ? Model.Price.Value.ToString("0.00") : "—")</dd>
        </dl>

        
        <!-- =====================================================
             ACTION BUTTONS
             ===================================================== -->
        <div style="margin-top: 12px; display: flex; gap: 8px;">

            <a asp-action="Edit"
                   asp-route-id="@Model?.FrameId"
                   class="button small">
                Edit
            </a>

            <a asp-action="Delete"
                   asp-route-id="@Model?.FrameId"
                   class="button small">
                Delete
            </a>

            <a asp-action="Index"
                   class="button small">
                Back to List
            </a>

        </div>

    </div>

</body>
</html>