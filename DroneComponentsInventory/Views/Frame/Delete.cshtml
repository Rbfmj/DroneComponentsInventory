@model DroneComponentsInventory.Models.FrameComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Dzēst rāmi</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/frames.css" />
</head>
<body class="is-preload">

    <div class="frames-panel">

        <h3 style="margin-top: 0;">
            Dzēst rāmi
        </h3>

        <p>
            Vai tiešām vēlaties dzēst šo rāmi?
            <strong>Šo darbību nevar atsaukt.</strong>
        </p>

        <hr />

        <dl class="frames-meta">

            <dt>Ražotājs</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Modelis</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Riteņa bāze (mm)</dt>
            <dd>@Html.DisplayFor(m => m.WheelbaseMm)</dd>

            <dt>Maks. propelleru izmērs (collas)</dt>
            <dd>@Html.DisplayFor(m => m.MaxPropInch)</dd>

            <dt>Ģeometrija</dt>
            <dd>@Html.DisplayFor(m => m.Geometry)</dd>

            <dt>Materiāls</dt>
            <dd>@Html.DisplayFor(m => m.Material)</dd>

            <dt>Roku biezums (mm)</dt>
            <dd>@Html.DisplayFor(m => m.ArmThicknessMm)</dd>

            <dt>Motora stiprinājums</dt>
            <dd>@Html.DisplayFor(m => m.MotorMountPattern)</dd>

            <dt>FC stiprinājuma raksts</dt>
            <dd>@Html.DisplayFor(m => m.FcMountPattern)</dd>

            <dt>Maks. kārbu augstums (mm)</dt>
            <dd>@Html.DisplayFor(m => m.MaxStackHeightMm)</dd>

            <dt>Svars (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt> cena</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="FrameId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Atcelt
                </a>

                <input type="submit"
                       value="Dzēst"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>