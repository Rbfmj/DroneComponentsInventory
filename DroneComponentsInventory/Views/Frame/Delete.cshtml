@model DroneComponentsInventory.Models.FrameComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete Frame</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/frames.css" />
</head>
<body class="is-preload">

    <div class="frames-panel">

        <h3 style="margin-top: 0;">
            Delete Frame
        </h3>

        <p>
            Are you sure you want to delete this frame?
            <strong>This action cannot be undone.</strong>
        </p>

        <hr />

        <dl class="frames-meta">

            <dt>Manufacturer</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Model</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Wheelbase (mm)</dt>
            <dd>@Html.DisplayFor(m => m.WheelbaseMm)</dd>

            <dt>Max Prop Size (in)</dt>
            <dd>@Html.DisplayFor(m => m.MaxPropInch)</dd>

            <dt>Geometry</dt>
            <dd>@Html.DisplayFor(m => m.Geometry)</dd>

            <dt>Material</dt>
            <dd>@Html.DisplayFor(m => m.Material)</dd>

            <dt>Arm Thickness (mm)</dt>
            <dd>@Html.DisplayFor(m => m.ArmThicknessMm)</dd>

            <dt>Motor Mount</dt>
            <dd>@Html.DisplayFor(m => m.MotorMountPattern)</dd>

            <dt>FC Mount Pattern</dt>
            <dd>@Html.DisplayFor(m => m.FcMountPattern)</dd>

            <dt>Max Stack Height (mm)</dt>
            <dd>@Html.DisplayFor(m => m.MaxStackHeightMm)</dd>

            <dt>Weight (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="FrameId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Cancel
                </a>

                <input type="submit"
                       value="Delete"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>