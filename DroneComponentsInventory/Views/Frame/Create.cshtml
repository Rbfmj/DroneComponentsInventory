@model DroneComponentsInventory.Models.FrameComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Pievienot FPV rāmi</title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/frames.css" />
</head>
<body class="is-preload">
    <div class="frames-panel">
        <h2>Pievienot FPV rāmi</h2>
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="Manufacturer" class="control-label">Ražotājs</label>
                    <input asp-for="Manufacturer" class="form-control" />
                    <span asp-validation-for="Manufacturer" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Model" class="control-label">Modelis</label>
                    <input asp-for="Model" class="form-control" />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="WheelbaseMm" class="control-label">Riteņu bāze (mm)</label>
                    <input asp-for="WheelbaseMm" class="form-control" type="number" step="1" />
                    <span asp-validation-for="WheelbaseMm" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MaxPropInch" class="control-label">Maksimālais propelleru izmērs (collas)</label>
                    <input asp-for="MaxPropInch" class="form-control" type="number" step="0.5" />
                    <span asp-validation-for="MaxPropInch" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Geometry" class="control-label">Ģeometrija</label>
                    <input asp-for="Geometry" class="form-control" />
                    <span asp-validation-for="Geometry" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Material" class="control-label">Materiāls</label>
                    <input asp-for="Material" class="form-control" />
                    <span asp-validation-for="Material" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="WeightG" class="control-label">Svars (g)</label>
                    <input asp-for="WeightG" class="form-control" type="number" step="0.1" />
                    <span asp-validation-for="WeightG" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ArmThicknessMm" class="control-label">Roka biezums (mm)</label>
                    <input asp-for="ArmThicknessMm" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="ArmThicknessMm" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MotorMountPattern" class="control-label">Motora stiprinājuma raksts</label>
                    <input asp-for="MotorMountPattern" class="form-control" />
                    <span asp-validation-for="MotorMountPattern" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="FcMountPattern" class="control-label">FC stiprinājuma raksts</label>
                    <input asp-for="FcMountPattern" class="form-control" />
                    <span asp-validation-for="FcMountPattern" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MaxStackHeightMm" class="control-label">Maksimālais kaudzes augstums (mm)</label>
                    <input asp-for="MaxStackHeightMm" class="form-control" type="number" step="1" />
                    <span asp-validation-for="MaxStackHeightMm" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Price" class="control-label">Cena</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

            </div>

            <div style="margin-top: 24px; display: flex; gap: 12px;">
                <input type="submit" value="Izveidot" class="button small" />
                <a asp-action="Index" class="button small">Atcelt</a>
            </div>

        </form>

    </div>

</body>
</html>