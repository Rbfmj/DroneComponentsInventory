@model IReadOnlyList<DroneComponentsInventory.Models.DroneBuild>
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Build your Drone</title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/home.css" />
</head>

<body class="is-preload">

    <partial name="_IndexQuickNav" />

    <div class="home-view home-builds-view">
        <div class="wrapper style1 align-center">
            <div class="inner">
                <section class="home-hero">
                    <h1>Build your Drone</h1>
                    <p>
                        Select a build to start or create a new build.
                    </p>
                    <div class="hero-actions">
                        <a asp-controller="DroneBuilder" asp-action="Index" class="button small">Create a new build</a>
                    </div>
                </section>
            </div>
        </div>


        <div class="wrapper">
            <div class="inner">
                <section class="build-grid home-grid" id="homeGrid">
                    @foreach (var build in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.DroneBuild>())
                    {
                    <article class="build-card home-tile"
                             data-modal-id="hmodal-@build.BuildId">
                        <div class="build-card-header">
                            <span class="build-card-label muted">Build</span>
                            <h3 class="title">@build.Name</h3>
                        </div>
                    </article>
                    }
                </section>
            </div>
        </div>

        @foreach (var build in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.DroneBuild>())
        {
        <div id="hmodal-@build.BuildId"
             class="home-modal"
             style="display:none;"
             aria-hidden="true">
            <div class="panel">
                <button type="button"
                        class="button small close-modal"
                        style="position:absolute; right:12px; top:12px;">
                    ×
                </button>

                <h2>@build.Name</h2>

                <dl class="build-meta">
                    <dt>Build ID</dt>
                    <dd>@build.BuildId</dd>

                    <dt>Created</dt>
                    <dd>@build.CreatedAt.ToLocalTime().ToString("f")</dd>

                    <dt>Frame</dt>
                    <dd>@(build.Frame is null ? "—" : $"{build.Frame.Manufacturer} {build.Frame.Model}")</dd>

                    <dt>Motor</dt>
                    <dd>@(build.Motor is null ? "—" : $"{build.Motor.Manufacturer} {build.Motor.Model}")</dd>

                    <dt>Battery</dt>
                    <dd>@(build.Battery is null ? "—" : $"{build.Battery.Manufacturer} {build.Battery.Model}")</dd>

                    <dt>Flight Controller</dt>
                    <dd>@(build.Fc is null ? "—" : $"{build.Fc.Manufacturer} {build.Fc.Model}")</dd>
                </dl>

                <div style="margin-top:16px; display:flex; gap:12px; justify-content:flex-end; flex-wrap:wrap;">
                    <a class="button small"
                       asp-controller="DroneBuilder"
                       asp-action="Assembly"
                       asp-route-id="@build.BuildId">
                        Assembly
                    </a>

                    <a class="button small"
                       asp-controller="DroneBuilder"
                       asp-action="Details"
                       asp-route-id="@build.BuildId">
                        Details
                    </a>

                    <a class="button small danger"
                       asp-controller="DroneBuilder"
                       asp-action="Delete"
                       asp-route-id="@build.BuildId">
                        Delete
                    </a>

                    <button type="button"
                            class="button small close-modal">
                        Close
                    </button>
                </div>
            </div>
        </div>
        }

        <script src="/js/home-modals.js"></script>
    </div>
</body>

</html>
