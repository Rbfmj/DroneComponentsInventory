@model DroneComponentsInventory.Models.FPVGogglesComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete FPV Goggles</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/fpvgoggles.css" />
</head>
<body class="is-preload">

    <div class="fpvgoggles-panel">

        <h3 style="margin-top: 0;">
            Delete FPV Goggles
        </h3>

        <p>
            Are you sure you want to delete this goggles set?
            <strong>This action cannot be undone.</strong>
        </p>

        <hr />

        <dl class="fpvgoggles-meta">

            <dt>Manufacturer</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Model</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Video System</dt>
            <dd>@Html.DisplayFor(m => m.VideoSystem)</dd>

            <dt>Display Type</dt>
            <dd>@Html.DisplayFor(m => m.DisplayType)</dd>

            <dt>Screen Size (in)</dt>
            <dd>@Html.DisplayFor(m => m.ScreenSizeInch)</dd>

            <dt>Resolution</dt>
            <dd>@Html.DisplayFor(m => m.Resolution)</dd>

            <dt>Latency (ms)</dt>
            <dd>@Html.DisplayFor(m => m.LatencyMs)</dd>

            <dt>Receiver Type</dt>
            <dd>@Html.DisplayFor(m => m.ReceiverType)</dd>

            <dt>Diversity Antennas</dt>
            <dd>@Html.DisplayFor(m => m.DiversityAntennas)</dd>

            <dt>Weight (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>DVR Capability</dt>
            <dd>@(Model.DvrCapability ? "Yes" : "No")</dd>

            <dt>Battery Life (h)</dt>
            <dd>@Html.DisplayFor(m => m.BatteryLifeHours)</dd>

            <dt>Power Input</dt>
            <dd>@Html.DisplayFor(m => m.PowerInput)</dd>

            <dt>IPD Adjustable</dt>
            <dd>@(Model.IpdAdjustable ? "Yes" : "No")</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="FpvGogglesId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Cancel
                </a>

                <input type="submit"
                       value="Delete"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>