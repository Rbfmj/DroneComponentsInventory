@model DroneComponentsInventory.Models.FPVGogglesComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Dzēst FPV brilles</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/fpvgoggles.css" />
</head>
<body class="is-preload">

    <div class="fpvgoggles-panel">

        <h3 style="margin-top: 0;">
            Dzēst FPV brilles
        </h3>

        <p>
            Vai tiešām vēlaties dzēst šīs brilles?
            <strong>Šo darbību nevar atsaukt.</strong>
        </p>

        <hr />

        <dl class="fpvgoggles-meta">

            <dt>Ražotājs</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Modelis</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Video sistēma</dt>
            <dd>@Html.DisplayFor(m => m.VideoSystem)</dd>

            <dt>Displeja veids</dt>
            <dd>@Html.DisplayFor(m => m.DisplayType)</dd>

            <dt>Ekraana izmērs (collas)</dt>
            <dd>@Html.DisplayFor(m => m.ScreenSizeInch)</dd>

            <dt>Izšķirtspēja</dt>
            <dd>@Html.DisplayFor(m => m.Resolution)</dd>

            <dt>Latence (ms)</dt>
            <dd>@Html.DisplayFor(m => m.LatencyMs)</dd>

            <dt>Uztvērēja veids</dt>
            <dd>@Html.DisplayFor(m => m.ReceiverType)</dd>

            <dt>Diversitātes antenas</dt>
            <dd>@Html.DisplayFor(m => m.DiversityAntennas)</dd>

            <dt>Svars (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>DVR funkcionalitāte</dt>
            <dd>@(Model.DvrCapability ? "Jā" : "Nē")</dd>

            <dt>Akumulatora darbības laiks (h)</dt>
            <dd>@Html.DisplayFor(m => m.BatteryLifeHours)</dd>

            <dt>Barošanas ievade</dt>
            <dd>@Html.DisplayFor(m => m.PowerInput)</dd>

            <dt>IPD regulējams</dt>
            <dd>@(Model.IpdAdjustable ? "Jā" : "Nē")</dd>

            <dt>Cena</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="FpvGogglesId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Atcelt
                </a>

                <input type="submit"
                       value="Dzēst"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>