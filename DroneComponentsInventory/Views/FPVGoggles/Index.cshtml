@model IEnumerable<DroneComponentsInventory.Models.FPVGogglesComponent>
@using System.Linq

@{
    /* This view is rendered standalone (no shared layout) */
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <!-- Basic responsive meta -->
    <meta name="viewport" content="width=device-width" />

    <title>Brilles</title>

    <!-- Core site styles -->
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/fpvgoggles.css" />
</head>

<body class="is-preload">

    <partial name="_IndexQuickNav" />

    <div class="fpvgoggles-view">

        <div class="wrapper style1 align-center">
            <div class="inner">
                <h2>Brilles</h2>

                <p>Izvēlieties brilles, lai skatītu tehnisko specifikāciju.</p>

                <p>
                    <a asp-action="Create" class="button small">Pievienot jaunas brilles</a>
                </p>
            </div>
        </div>

        <div class="wrapper">
            <div class="inner">

                <div class="fpvgoggles-grid" id="fpvgogglesGrid">

                    @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.FPVGogglesComponent>())
                    {
                        <article class="fpvgoggles-tile" data-modal-id="gmodal-@item.FpvGogglesId">
                            <div>
                                <span class="title">@item.Manufacturer</span>
                                <span class="muted">@item.Model</span>
                            </div>
                        </article>
                    }

                </div>

            </div>
        </div>

        @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.FPVGogglesComponent>())
        {
            <div id="gmodal-@item.FpvGogglesId" class="fpvgoggles-modal" style="display:none;" aria-hidden="true">
                <div class="panel">

                    <button type="button" class="button small close-modal" style="position:absolute; right:12px; top:12px;">×</button>

                    <h2>@item.Manufacturer @item.Model</h2>

                    <dl class="fpvgoggles-meta">
                        <dt>Video sistēma</dt>
                        <dd>@item.VideoSystem</dd>

                        <dt>Displeja veids</dt>
                        <dd>@item.DisplayType</dd>

                        <dt>Ekraņa izmērs</dt>
                        <dd>@(item.ScreenSizeInch?.ToString() + " in" ?? "")</dd>

                        <dt>Izšķirtspēja</dt>
                        <dd>@item.Resolution</dd>

                        <dt>Atsauce</dt>
                        <dd>@(item.LatencyMs?.ToString() + " ms" ?? "")</dd>

                        <dt>Uztvērēja veids</dt>
                        <dd>@item.ReceiverType</dd>

                        <dt>Diversitātes antenas</dt>
                        <dd>@item.DiversityAntennas</dd>

                        <dt>Svars</dt>
                        <dd>@(item.WeightG?.ToString() + " g" ?? "")</dd>

                        <dt>DVR</dt>
                        <dd>@(item.DvrCapability ? "Jā" : "Nē")</dd>

                        <dt>Akumulatora darbības laiks</dt>
                        <dd>@(item.BatteryLifeHours?.ToString() + " h" ?? "")</dd>

                        <dt>Barošanas ievade</dt>
                        <dd>@item.PowerInput</dd>

                        <dt>IPD regulējams</dt>
                        <dd>@(item.IpdAdjustable ? "Jā" : "Nē")</dd>

                        <dt>Cena</dt>
                        <dd>@(item.Price.HasValue ? item.Price.Value.ToString("0.00") : "")</dd>
                    </dl>

                    <div style="margin-top:16px; display:flex; gap:12px; justify-content:flex-end;">
                        <a class="button small" asp-action="Edit" asp-route-id="@item.FpvGogglesId">Rediģēt</a>
                        <a class="button small" asp-action="Details" asp-route-id="@item.FpvGogglesId">Detalizēti</a>
                        <a class="button small danger" asp-action="Delete" asp-route-id="@item.FpvGogglesId">Dzēst</a>
                        <button type="button" class="button small close-modal">Aizvērt</button>
                    </div>

                </div>
            </div>
        }

    </div>

    <script src="/js/fpvgoggles-modals.js"></script>

</body>
</html>
