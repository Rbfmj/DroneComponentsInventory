@model DroneComponentsInventory.Models.FPVGogglesComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <!-- Responsive viewport -->
    <meta name="viewport" content="width=device-width" />

    <!-- Core site styles -->
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/fpvgoggles.css" />
</head>

<body class="is-preload">

    <div class="fpvgoggles-panel">

        <h2>FPV briļļu detaļas</h2>

        <hr />

        <dl class="fpvgoggles-meta">

            <dt>Ražotājs</dt>
            <dd>@(Model.Manufacturer ?? string.Empty)</dd>

            <dt>Modelis</dt>
            <dd>@(Model.Model ?? string.Empty)</dd>

            <dt>Video sistēma</dt>
            <dd>@(Model.VideoSystem ?? string.Empty)</dd>

            <dt>Displeja tips</dt>
            <dd>@(Model.DisplayType ?? string.Empty)</dd>

            <dt>Ekraņa izmērs</dt>
            <dd>@(Model.ScreenSizeInch.HasValue ? Model.ScreenSizeInch.Value + " in" : string.Empty)</dd>

            <dt>Izšķirtspēja</dt>
            <dd>@(Model.Resolution ?? string.Empty)</dd>

            <dt>Atruna (ms)</dt>
            <dd>@(Model.LatencyMs.HasValue ? Model.LatencyMs.Value + " ms" : string.Empty)</dd>

            <dt>Uztvērēja tips</dt>
            <dd>@(Model.ReceiverType ?? string.Empty)</dd>

            <dt>Diversitātes antenas</dt>
            <dd>@(Model.DiversityAntennas.HasValue ? Model.DiversityAntennas.Value.ToString() : string.Empty)</dd>

            <dt>Svars (g)</dt>
            <dd>@(Model.WeightG.HasValue ? Model.WeightG.Value + " g" : string.Empty)</dd>

            <dt>DVR funkcionalitāte</dt>
            <dd>@(Model.DvrCapability ? "Jā" : "Nē")</dd>

            <dt>Akumulatora darbības laiks (h)</dt>
            <dd>@(Model.BatteryLifeHours.HasValue ? Model.BatteryLifeHours.Value + " h" : string.Empty)</dd>

            <dt>Barošanas ieeja</dt>
            <dd>@(Model.PowerInput ?? string.Empty)</dd>

            <dt>IPD regulējams</dt>
            <dd>@(Model.IpdAdjustable ? "Jā" : "Nē")</dd>

            <dt>Cena</dt>
            <dd>@(Model.Price.HasValue ? Model.Price.Value.ToString("0.00") : string.Empty)</dd>

        </dl>

        
        <!-- =====================================================
             AKCIJAS POGAS
             ===================================================== -->
        <div style="margin-top: 12px; display: flex; gap: 8px;">

            <a asp-action="Edit"
                   asp-route-id="@Model?.FpvGogglesId"
                   class="button small">
                Rediģēt
            </a>

            <a asp-action="Delete"
                   asp-route-id="@Model?.FpvGogglesId"
                   class="button small">
                Dzēst
            </a>

            <a asp-action="Index"
                   class="button small">
                Atgriezties pie saraksta
            </a>

        </div>

    </div>

</body>
</html>
