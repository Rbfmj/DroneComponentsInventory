@model DroneComponentsInventory.Models.FPVGogglesComponent

@{
    /* Standalone view (no shared layout used) */
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <!-- Responsive scaling for mobile devices -->
    <meta name="viewport" content="width=device-width" />

    <!-- Core site styles -->
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/fpvgoggles.css" />
</head>

<body class="is-preload">

    <div class="fpvgoggles-panel">

        <h2>Pievienot FPV brilles</h2>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="Manufacturer" class="control-label">Ražotājs</label>
                    <input asp-for="Manufacturer" class="form-control" />
                    <span asp-validation-for="Manufacturer" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Model" class="control-label">Modelis</label>
                    <input asp-for="Model" class="form-control" />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="VideoSystem" class="control-label">Video sistēma</label>
                    <input asp-for="VideoSystem" class="form-control" />
                    <span asp-validation-for="VideoSystem" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DisplayType" class="control-label">Displeja veids</label>
                    <input asp-for="DisplayType" class="form-control" />
                    <span asp-validation-for="DisplayType" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ScreenSizeInch" class="control-label">Ekrāna izmērs (collās)</label>
                    <input asp-for="ScreenSizeInch" class="form-control" type="number" step="any" />
                    <span asp-validation-for="ScreenSizeInch" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Resolution" class="control-label">Izšķirtspēja</label>
                    <input asp-for="Resolution" class="form-control" />
                    <span asp-validation-for="Resolution" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="LatencyMs" class="control-label">Aizture (ms)</label>
                    <input asp-for="LatencyMs" class="form-control" type="number" />
                    <span asp-validation-for="LatencyMs" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ReceiverType" class="control-label">Uztvērēja tips</label>
                    <input asp-for="ReceiverType" class="form-control" />
                    <span asp-validation-for="ReceiverType" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DiversityAntennas" class="control-label">Darbības antenas</label>
                    <input asp-for="DiversityAntennas" class="form-control" type="number" />
                    <span asp-validation-for="DiversityAntennas" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="WeightG" class="control-label">Svars (g)</label>
                    <input asp-for="WeightG" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="WeightG" class="text-danger"></span>
                </div>

                <div class="form-group checkbox-group">
                    <label asp-for="DvrCapability" class="control-label">DVR funkcionalitāte</label>
                    <input asp-for="DvrCapability" type="checkbox" class="fpv-checkbox" />
                    <span asp-validation-for="DvrCapability" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="BatteryLifeHours" class="control-label">Akkumulatora darbības laiks (h)</label>
                    <input asp-for="BatteryLifeHours" class="form-control" type="number" step="any" />
                    <span asp-validation-for="BatteryLifeHours" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PowerInput" class="control-label">Jaudas ieeja</label>
                    <input asp-for="PowerInput" class="form-control" />
                    <span asp-validation-for="PowerInput" class="text-danger"></span>
                </div>

                <div class="form-group checkbox-group">
                    <label asp-for="IpdAdjustable" class="control-label">IPD regulējams</label>
                    <input asp-for="IpdAdjustable" type="checkbox" class="fpv-checkbox" />
                    <span asp-validation-for="IpdAdjustable" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Price" class="control-label">Cena</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

            </div>

            <div style="margin-top: 12px; display: flex; gap: 8px;">
                <input type="submit" value="Izveidot" class="button small" />
                <a asp-action="Index" class="button small">Atcelt</a>
            </div>

        </form>

    </div>

</body>
</html>
