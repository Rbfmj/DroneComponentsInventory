@model DroneComponentsInventory.Models.ReceiverAntennaComponent

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Dzēst uztvērēja antenu</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/receiverantennas.css" />
</head>
<body class="is-preload">

    <div class="receiverantennas-panel">

        <h3 style="margin-top: 0;">
            Dzēst uztvērēja antenu
        </h3>

        <p>
            Vai tiešām vēlaties dzēst šo uztvērēja antenu?
            <strong>Šo darbību nevar atsaukt.</strong>
        </p>

        <hr />

        <dl class="receiverantennas-meta">

            <dt>Ražotājs</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Modelis</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Frekvences josla</dt>
            <dd>@Html.DisplayFor(m => m.FrequencyBand)</dd>

            <dt>Polarizācija</dt>
            <dd>@Html.DisplayFor(m => m.Polarization)</dd>

            <dt>Connector</dt>
            <dd>@Html.DisplayFor(m => m.Connector)</dd>

            <dt>Connector dzimums</dt>
            <dd>@Html.DisplayFor(m => m.ConnectorGender)</dd>

            <dt>Vērtība (dBi)</dt>
            <dd>@Html.DisplayFor(m => m.GainDbi)</dd>

            <dt>Iejošā patern</dt>
            <dd>@Html.DisplayFor(m => m.RadiationPattern)</dd>

            <dt>Montāžas veids</dt>
            <dd>@Html.DisplayFor(m => m.MountType)</dd>

            <dt>Kabeļa garums (mm)</dt>
            <dd>@Html.DisplayFor(m => m.CableLengthMm)</dd>

            <dt>Svars (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Garums (mm)</dt>
            <dd>@Html.DisplayFor(m => m.LengthMm)</dd>

            <dt>Cena</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="ReceiverAntennaId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Atcelt
                </a>

                <input type="submit"
                       value="Dzēst"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html></html>