@model DroneComponentsInventory.Models.ReceiverAntennaComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Uztvērēja antenas detaļas</title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/receiverantennas.css" />
</head>
<body class="is-preload">
    <div class="receiverantennas-panel">
        <h2>@Model.Manufacturer @Model.Model</h2>
        <dl class="receiverantennas-meta">
            <dt>Frekvenču josla</dt>
            <dd>@(Model.FrequencyBand ?? "—")</dd>

            <dt>Polarizācija</dt>
            <dd>@(Model.Polarization ?? "—")</dd>

            <dt>Konektors</dt>
            <dd>@(Model.Connector ?? "—") @Model.ConnectorGender</dd>

            <dt>Iegūšana</dt>
            <dd>@(Model.GainDbi?.ToString() + " dBi" ?? "—")</dd>

            <dt>Radiācijas raksts</dt>
            <dd>@(Model.RadiationPattern ?? "—")</dd>

            <dt>Savienojamie uztvērēji</dt>
            <dd>@(Model.CompatibleReceivers ?? "—")</dd>

            <dt>Montāžas veids</dt>
            <dd>@(Model.MountType ?? "—")</dd>

            <dt>Kabeļa garums</dt>
            <dd>@(Model.CableLengthMm?.ToString() + " mm" ?? "—")</dd>

            <dt>Svars</dt>
            <dd>@(Model.WeightG?.ToString() + " g" ?? "—")</dd>

            <dt>Garums</dt>
            <dd>@(Model.LengthMm?.ToString() + " mm" ?? "—")</dd>

            <dt> cena</dt>
            <dd>@(Model.Price.HasValue ? "$" + Model.Price.Value.ToString("0.00") : "—")</dd>
        </dl>

        
        <!-- =====================================================
             ACTION BUTTONS (your new style)
             ===================================================== -->
        <div style="margin-top: 12px; display: flex; gap: 8px;">

            <a asp-action="Edit"
                   asp-route-id="@Model?.ReceiverAntennaId"
                   class="button small">
                Rediģēt
            </a>

            <a asp-action="Delete"
                   asp-route-id="@Model?.ReceiverAntennaId"
                   class="button small">
                Dzēst
            </a>

            <a asp-action="Index"
                   class="button small">
                Atpakaļ uz sarakstu
            </a>

        </div>

    </div>

</body>
</html>