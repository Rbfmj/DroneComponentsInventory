<div class="index-quick-nav" id="indexQuickNav">
    <button type="button" class="button small index-quick-nav-toggle" id="indexQuickNavToggle" aria-label="Open navigation">≡</button>
    <div class="index-quick-nav-menu" id="indexQuickNavMenu">
        <a asp-controller="Home" asp-action="Index">Home</a>
        <a asp-controller="DroneBuilder" asp-action="Index">Drone Builder</a>
        <a asp-controller="Frame" asp-action="Index">Frames</a>
        <a asp-controller="Battery" asp-action="Index">Batteries</a>
        <a asp-controller="ESC" asp-action="Index">ESC</a>
        <a asp-controller="FC" asp-action="Index">Flight Controller</a>
        <a asp-controller="FPVCamera" asp-action="Index">FPV Camera</a>
        <a asp-controller="FPVGoggles" asp-action="Index">FPV Goggles</a>
        <a asp-controller="Motors" asp-action="Index">Motors</a>
        <a asp-controller="Propellers" asp-action="Index">Propellers</a>
        <a asp-controller="RadioController" asp-action="Index">Radio Controller</a>
        <a asp-controller="Receiver" asp-action="Index">Receiver</a>
        <a asp-controller="ReceiverAntenna" asp-action="Index">Receiver Antenna</a>
        <a asp-controller="VideoAntenna" asp-action="Index">Video Antenna</a>
        <a asp-controller="VideoTransmitter" asp-action="Index">Video Transmitter</a>
    </div>
</div>

<style>
    .index-quick-nav {
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 10000;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .index-quick-nav-toggle {
        min-width: 3.2rem;
        text-align: center;
        padding-left: 0.9rem;
        padding-right: 0.9rem;
        font-size: 1rem;
        line-height: 1;
    }

    .index-quick-nav-menu {
        margin-top: 0.5rem;
        width: 15rem;
        max-height: 0;
        overflow: hidden;
        opacity: 0;
        transform: translateY(-8px);
        transition: max-height 0.32s ease, opacity 0.22s ease, transform 0.22s ease;
        background: rgba(255, 255, 255, 0.98);
        border: 1px solid rgba(0, 0, 0, 0.08);
        border-radius: 0.65rem;
        box-shadow: 0 10px 22px rgba(0, 0, 0, 0.14);
        padding: 0;
    }

    .index-quick-nav.open .index-quick-nav-menu {
        max-height: 26rem;
        opacity: 1;
        transform: translateY(0);
        overflow: auto;
    }

    .index-quick-nav-menu a {
        display: block;
        text-decoration: none;
        color: #111827;
        padding: 0.6rem 0.8rem;
        line-height: 1.2;
        font-size: 0.85rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    }

    .index-quick-nav-menu a:last-child {
        border-bottom: 0;
    }

    .index-quick-nav-menu a:hover {
        background: rgba(31, 41, 55, 0.08);
    }
</style>

<script>
    (function () {
        var root = document.getElementById('indexQuickNav');
        var toggle = document.getElementById('indexQuickNavToggle');
        if (!root || !toggle) {
            return;
        }

        toggle.addEventListener('click', function (e) {
            e.stopPropagation();
            root.classList.toggle('open');
        });

        document.addEventListener('click', function (e) {
            if (!root.contains(e.target)) {
                root.classList.remove('open');
            }
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                root.classList.remove('open');
            }
        });
    })();
</script>
