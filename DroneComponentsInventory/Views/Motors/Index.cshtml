@model IEnumerable<DroneComponentsInventory.Models.MotorsComponent>
@using System.Linq

@{
    /* This view is rendered standalone (no shared layout) */
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <!-- Basic responsive meta -->
    <meta name="viewport" content="width=device-width" />

    <title>Motori</title>

    <!-- Core site styles -->
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/motors.css" />
</head>

<body class="is-preload">

    <partial name="_IndexQuickNav" />

    <div class="motors-view">

        <div class="wrapper style1 align-center">
            <div class="inner">
                <h2>Motori</h2>

                <p>Izvēlieties motoru, lai skatītu tehnisko specifikāciju.</p>

                <p>
                    <a asp-action="Create" class="button small">Pievienot jaunu motoru</a>
                </p>
            </div>
        </div>

        <div class="wrapper">
            <div class="inner">

                <div class="motors-grid" id="motorsGrid">

                    @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.MotorsComponent>())
                    {
                        <article class="motors-tile" data-modal-id="mmmodal-@item.MotorId">
                            <div>
                                <span class="title">@item.Manufacturer</span>
                                <span class="muted">@item.Model</span>
                            </div>
                        </article>
                    }

                </div>

            </div>
        </div>

        @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.MotorsComponent>())
        {
            <div id="mmmodal-@item.MotorId" class="motors-modal" style="display:none;" aria-hidden="true">
                <div class="panel">

                    <button type="button" class="button small close-modal" style="position:absolute; right:12px; top:12px;">×</button>

                    <h2>@item.Manufacturer @item.Model</h2>

                    <dl class="motors-meta">
                        <dt>Statora izmērs</dt>
                        <dd>@(item.StatorSizeMm?.ToString() + " mm" ?? "")</dd>

                        <dt>KV vērtība</dt>
                        <dd>@item.Kv</dd>

                        <dt>Montāžas raksts</dt>
                        <dd>@item.MountPattern</dd>

                        <dt>Svars</dt>
                        <dd>@(item.WeightG?.ToString() + " g" ?? "")</dd>

                        <dt>Rekomendētais spriegums</dt>
                        <dd>@item.RecommendedVoltageS S</dd>

                        <dt>Rekomendētā props</dt>
                        <dd>@(item.RecommendedPropInch?.ToString() + "\"" ?? "")</dd>

                        <dt>Maks. spiediens</dt>
                        <dd>@(item.MaxThrustG?.ToString() + " g" ?? "")</dd>

                        <dt>Cena</dt>
                        <dd>@(item.Price.HasValue? item.Price.Value.ToString("0.00") : "")</dd>
                    </dl>

                    <div style="margin-top:16px; display:flex; gap:12px; justify-content:flex-end;">
                        <a class="button small" asp-action="Edit" asp-route-id="@item.MotorId">Rediģēt</a>
                        <a class="button small" asp-action="Details" asp-route-id="@item.MotorId">Detalizēti</a>
                        <a class="button small danger" asp-action="Delete" asp-route-id="@item.MotorId">Dzēst</a>
                        <button type="button" class="button small close-modal">Aizvērt</button>
                    </div>

                </div>
            </div>
        }

    </div>

    <script src="/js/motors-modals.js"></script>

</body>
</html>