@model DroneComponentsInventory.Models.MotorsComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Motor Details</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/motors.css" />
</head>

<body class="is-preload">

    <div class="motors-panel">

        <h2>@Model.Manufacturer @Model.Model</h2>

        <dl class="motors-meta">
            <dt>Stator Size</dt>
            <dd>@(Model.StatorSizeMm?.ToString() + " mm" ?? "—")</dd>

            <dt>KV Rating</dt>
            <dd>@(Model.Kv?.ToString() ?? "—")</dd>

            <dt>Mount Pattern</dt>
            <dd>@(Model.MountPattern ?? "—")</dd>

            <dt>Weight</dt>
            <dd>@(Model.WeightG?.ToString() + " g" ?? "—")</dd>

            <dt>Recommended Voltage</dt>
            <dd>@(Model.RecommendedVoltageS?.ToString() ?? "—")</dd>

            <dt>Recommended Prop</dt>
            <dd>@(Model.RecommendedPropInch?.ToString() + "\"" ?? "—")</dd>

            <dt>Max Thrust</dt>
            <dd>@(Model.MaxThrustG?.ToString() + " g" ?? "—")</dd>

            <dt>Price</dt>
            <dd>@(Model.Price.HasValue ? "$" + Model.Price.Value.ToString("0.00") : "—")</dd>
        </dl>

        
        <!-- =====================================================
             ACTION BUTTONS
             ===================================================== -->
        <div style="margin-top: 12px; display: flex; gap: 8px;">

            <a asp-action="Edit"
                   asp-route-id="@Model?.MotorId"
                   class="button small">
                Edit
            </a>

            <a asp-action="Delete"
                   asp-route-id="@Model?.MotorId"
                   class="button small">
                Delete
            </a>

            <a asp-action="Index"
                   class="button small">
                Back to List
            </a>

        </div>

    </div>

</body>
</html>