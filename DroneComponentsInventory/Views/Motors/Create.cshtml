@model DroneComponentsInventory.Models.MotorsComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Create FPV Motor</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/motors.css" />
</head>

<body class="is-preload">

    <div class="motors-panel">

        <h2>Create FPV Motor</h2>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="Manufacturer" class="control-label">Manufacturer</label>
                    <input asp-for="Manufacturer" class="form-control" />
                    <span asp-validation-for="Manufacturer" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Model" class="control-label">Model</label>
                    <input asp-for="Model" class="form-control" />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="StatorSizeMm" class="control-label">Stator Size (mm)</label>
                    <input asp-for="StatorSizeMm" class="form-control" type="number" step="1" />
                    <span asp-validation-for="StatorSizeMm" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Kv" class="control-label">KV Rating</label>
                    <input asp-for="Kv" class="form-control" type="number" step="1" />
                    <span asp-validation-for="Kv" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MountPattern" class="control-label">Mount Pattern</label>
                    <input asp-for="MountPattern" class="form-control" />
                    <span asp-validation-for="MountPattern" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="WeightG" class="control-label">Weight (g)</label>
                    <input asp-for="WeightG" class="form-control" type="number" step="0.1" />
                    <span asp-validation-for="WeightG" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RecommendedVoltageS" class="control-label">Recommended Voltage (S)</label>
                    <input asp-for="RecommendedVoltageS" class="form-control" placeholder="e.g. 4-6S" />
                    <span asp-validation-for="RecommendedVoltageS" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RecommendedPropInch" class="control-label">Recommended Prop (inch)</label>
                    <input asp-for="RecommendedPropInch" class="form-control" type="number" step="0.5" />
                    <span asp-validation-for="RecommendedPropInch" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MaxThrustG" class="control-label">Max Thrust (g)</label>
                    <input asp-for="MaxThrustG" class="form-control" type="number" step="1" />
                    <span asp-validation-for="MaxThrustG" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Price" class="control-label">Price ($)</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

            </div>

            <div style="margin-top: 24px; display: flex; gap: 12px;">
                <input type="submit" value="Create" class="button small" />
                <a asp-action="Index" class="button small">Cancel</a>
            </div>

        </form>

    </div>

</body>
</html>