@model DroneComponentsInventory.Models.MotorsComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Rediģēt FPV motoru</title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/motors.css" />
</head>
<body class="is-preload">
    <div class="motors-panel">
        <h2>Rediģēt FPV motoru</h2>
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="MotorId" />

            <div class="form-grid">
                <!-- Same fields as Create.cshtml -->
                <div class="form-group">
                    <label asp-for="Manufacturer" class="control-label">Ražotājs</label>
                    <input asp-for="Manufacturer" class="form-control" />
                    <span asp-validation-for="Manufacturer" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Model" class="control-label">Modelis</label>
                    <input asp-for="Model" class="form-control" />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="StatorSizeMm" class="control-label">Statora izmērs (mm)</label>
                    <input asp-for="StatorSizeMm" class="form-control" type="number" step="any" />
                    <span asp-validation-for="StatorSizeMm" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Kv" class="control-label">KV reitings</label>
                    <input asp-for="Kv" class="form-control" type="number" step="1" />
                    <span asp-validation-for="Kv" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MountPattern" class="control-label">Montāžas raksts</label>
                    <input asp-for="MountPattern" class="form-control" />
                    <span asp-validation-for="MountPattern" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="WeightG" class="control-label">Svars (g)</label>
                    <input asp-for="WeightG" class="form-control" type="number" step="any" />
                    <span asp-validation-for="WeightG" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RecommendedVoltageS" class="control-label">Ieteicamais spriegums (S)</label>
                    <input asp-for="RecommendedVoltageS" class="form-control" />
                    <span asp-validation-for="RecommendedVoltageS" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RecommendedPropInch" class="control-label">Ieteicamā propelleru izmērs (collas)</label>
                    <input asp-for="RecommendedPropInch" class="form-control" type="number" step="any" />
                    <span asp-validation-for="RecommendedPropInch" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MaxThrustG" class="control-label">Maksimālais uzgriežņu spēks (g)</label>
                    <input asp-for="MaxThrustG" class="form-control" type="number" step="1" />
                    <span asp-validation-for="MaxThrustG" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Price" class="control-label">Cena</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

            </div>

            <div style="margin-top: 24px; display: flex; gap: 12px;">
                <input type="submit" value="Saglabāt" class="button small" />
                <a asp-action="Index" class="button small">Atcelt</a>
            </div>
        </form>

    </div>

</body>
</html>