@model DroneComponentsInventory.Models.MotorsComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete Motor</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/motors.css" />
</head>
<body class="is-preload">

    <div class="motors-panel">

        <h3 style="margin-top: 0;">
            Delete Motor
        </h3>

        <p>
            Are you sure you want to delete this motor?
            <strong>This action cannot be undone.</strong>
        </p>

        <hr />

        <dl class="motors-meta">

            <dt>Manufacturer</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Model</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Stator Size</dt>
            <dd>@Html.DisplayFor(m => m.StatorSizeMm)</dd>

            <dt>KV Rating</dt>
            <dd>@Html.DisplayFor(m => m.Kv)</dd>

            <dt>Mount Pattern</dt>
            <dd>@Html.DisplayFor(m => m.MountPattern)</dd>

            <dt>Recommended Voltage (S)</dt>
            <dd>@Html.DisplayFor(m => m.RecommendedVoltageS)</dd>

            <dt>Recommended Prop (in)</dt>
            <dd>@Html.DisplayFor(m => m.RecommendedPropInch)</dd>

            <dt>Max Thrust (g)</dt>
            <dd>@Html.DisplayFor(m => m.MaxThrustG)</dd>

            <dt>Weight (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="MotorId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Cancel
                </a>

                <input type="submit"
                       value="Delete"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>