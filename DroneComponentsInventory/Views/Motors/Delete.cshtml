@model DroneComponentsInventory.Models.MotorsComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Dzēst motoru</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/motors.css" />
</head>
<body class="is-preload">

    <div class="motors-panel">

        <h3 style="margin-top: 0;">
            Dzēst motoru
        </h3>

        <p>
            Vai tiešām vēlaties dzēst šo motoru?
            <strong>Šo darbību nevar atsaukt.</strong>
        </p>

        <hr />

        <dl class="motors-meta">

            <dt>Ražotājs</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Modelis</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Statora izmērs</dt>
            <dd>@Html.DisplayFor(m => m.StatorSizeMm)</dd>

            <dt>KV reitings</dt>
            <dd>@Html.DisplayFor(m => m.Kv)</dd>

            <dt>Montāžas raksts</dt>
            <dd>@Html.DisplayFor(m => m.MountPattern)</dd>

            <dt>Rekomendētais spriegums (S)</dt>
            <dd>@Html.DisplayFor(m => m.RecommendedVoltageS)</dd>

            <dt>Rekomendētā propelleru izmere (collas)</dt>
            <dd>@Html.DisplayFor(m => m.RecommendedPropInch)</dd>

            <dt>Maks. stūme (g)</dt>
            <dd>@Html.DisplayFor(m => m.MaxThrustG)</dd>

            <dt>Svars (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt> cena </dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="MotorId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Atcelt
                </a>

                <input type="submit"
                       value="Dzēst"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>