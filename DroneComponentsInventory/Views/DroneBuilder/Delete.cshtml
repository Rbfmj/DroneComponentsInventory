@model DroneComponentsInventory.Models.DroneBuild

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete Build</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/home.css" />
</head>
<body class="is-preload">

    <partial name="_IndexQuickNav" />

    <div class="home-view">
        <div class="build-panel">
            <h3 style="margin-top: 0;">Delete Build</h3>

            <p>
                Are you sure you want to delete this build?
                <strong>This action cannot be undone.</strong>
            </p>

            <hr />

            <dl class="build-meta">
                <dt>Frame</dt>
                <dd>@(Model.Frame is null ? "—" : $"{Model.Frame.Manufacturer} {Model.Frame.Model}")</dd>

                <dt>Motor</dt>
                <dd>@(Model.Motor is null ? "—" : $"{Model.Motor.Manufacturer} {Model.Motor.Model}")</dd>

                <dt>Propeller</dt>
                <dd>@(Model.Propeller is null ? "—" : $"{Model.Propeller.Manufacturer} {Model.Propeller.Model}")</dd>

                <dt>ESC</dt>
                <dd>@(Model.Esc is null ? "—" : $"{Model.Esc.Manufacturer} {Model.Esc.Model}")</dd>

                <dt>Battery</dt>
                <dd>@(Model.Battery is null ? "—" : $"{Model.Battery.Manufacturer} {Model.Battery.Model}")</dd>

                <dt>Flight Controller</dt>
                <dd>@(Model.Fc is null ? "—" : $"{Model.Fc.Manufacturer} {Model.Fc.Model}")</dd>

                <dt>FPV Camera</dt>
                <dd>@(Model.Camera is null ? "—" : $"{Model.Camera.Manufacturer} {Model.Camera.Model}")</dd>

                <dt>VTX</dt>
                <dd>@(Model.Vtx is null ? "—" : $"{Model.Vtx.Manufacturer} {Model.Vtx.Model}")</dd>

                <dt>Video Antenna</dt>
                <dd>@(Model.VideoAntenna is null ? "—" : $"{Model.VideoAntenna.Manufacturer} {Model.VideoAntenna.Model}")</dd>

                <dt>Receiver</dt>
                <dd>@(Model.Receiver is null ? "—" : $"{Model.Receiver.Manufacturer} {Model.Receiver.Model}")</dd>

                <dt>Receiver Antenna</dt>
                <dd>@(Model.ReceiverAntenna is null ? "—" : $"{Model.ReceiverAntenna.Manufacturer} {Model.ReceiverAntenna.Model}")</dd>

                <dt>Radio Controller</dt>
                <dd>@(Model.RadioController is null ? "—" : $"{Model.RadioController.Manufacturer} {Model.RadioController.Model}")</dd>

                <dt>FPV Goggles</dt>
                <dd>@(Model.FpvGoggles is null ? "—" : $"{Model.FpvGoggles.Manufacturer} {Model.FpvGoggles.Model}")</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="BuildId" />

                <div class="panel-actions">
                    <a asp-controller="Home" asp-action="Index" class="button small">Cancel</a>
                    <input type="submit" value="Delete" class="button small danger" />
                </div>
            </form>
        </div>
    </div>

</body>
</html>