@model DroneComponentsInventory.Models.ESCComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Dzēst ESC</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/esc.css" />
</head>
<body class="is-preload">

    <div class="esc-panel">

        <h3 style="margin-top: 0;">
            Dzēst ESC
        </h3>

        <p>
            Vai tiešām vēlaties dzēst šo ESC?
            <strong>Šo darbību nevar atsaukt.</strong>
        </p>

        <hr />

        <dl class="esc-meta">

            <dt>Ražotājs</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Modelis</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Tips</dt>
            <dd>@Html.DisplayFor(m => m.EscType)</dd>

            <dt>Pastāvīgais strāvas stiprums (A)</dt>
            <dd>@Html.DisplayFor(m => m.ContinuousCurrentA)</dd>

            <dt>Sprieguma Ievade (S)</dt>
            <dd>@Html.DisplayFor(m => m.VoltageInputS)</dd>

            <dt>Montāžas raksts (mm)</dt>
            <dd>@Html.DisplayFor(m => m.MountPatternMm)</dd>

            <dt>Atbalstītās protokols</dt>
            <dd>@Html.DisplayFor(m => m.SupportedProtocols)</dd>

            <dt>Svars (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Cena</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="EscId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Atcelt
                </a>

                <input type="submit"
                       value="Dzēst"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>