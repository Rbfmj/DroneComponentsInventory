@model IEnumerable<DroneComponentsInventory.Models.ESCComponent>
@using System.Linq

@{
    /* This view is rendered standalone (no shared layout) */
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>ESC Components</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/esc.css" />
</head>
<body class="is-preload">

    <partial name="_IndexQuickNav" />

    <div class="esc-view">

        <div class="wrapper style1 align-center">
            <div class="inner">
                <h2>ESC Components</h2>
                <p>Select an ESC to view specifications.</p>

                <p>
                    <a asp-action="Create" class="button small">Add New ESC</a>
                </p>
            </div>
        </div>

        <div class="wrapper">
            <div class="inner">
                <div class="esc-grid" id="escGrid">
                    @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.ESCComponent>())
                    {
                        <article class="esc-tile" data-modal-id="emodal-@item.EscId">
                            <div>
                                <span class="title">@item.Manufacturer</span>
                                <span class="muted">@item.Model</span>
                            </div>
                        </article>
                    }
                </div>
            </div>
        </div>

        @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.ESCComponent>())
        {
            <div id="emodal-@item.EscId" class="esc-modal" style="display:none;" aria-hidden="true">
                <div class="panel">
                    <button type="button" class="button small close-modal" style="position:absolute; right:12px; top:12px;">×</button>

                    <h2>@item.Manufacturer @item.Model</h2>

                    <dl class="esc-meta">
                        <dt>Type</dt>
                        <dd>@item.EscType</dd>

                        <dt>Continuous Current</dt>
                        <dd>@(item.ContinuousCurrentA?.ToString() + " A" ?? "")</dd>

                        <dt>Voltage Input</dt>
                        <dd>@(item.VoltageInputS?.ToString() + "S" ?? "")</dd>

                        <dt>Mount Pattern</dt>
                        <dd>@(item.MountPatternMm?.ToString() + " mm" ?? "")</dd>

                        <dt>Protocols</dt>
                        <dd>@item.SupportedProtocols</dd>

                        <dt>Weight</dt>
                        <dd>@(item.WeightG?.ToString() + " g" ?? "")</dd>

                        <dt>Price</dt>
                        <dd>@item.Price</dd>
                    </dl>

                    <div style="margin-top: 16px; display:flex; gap:12px; justify-content:flex-end;">
                        <a class="button small" asp-action="Edit" asp-route-id="@item.EscId">Edit</a>
                        <a class="button small" asp-action="Details" asp-route-id="@item.EscId">Details</a>
                        <a class="button small danger" asp-action="Delete" asp-route-id="@item.EscId">Delete</a>
                        <button type="button" class="button small close-modal">Close</button>
                    </div>
                </div>
            </div>
        }

    </div>

    <script src="/js/esc-modals.js"></script>

</body>
</html>
