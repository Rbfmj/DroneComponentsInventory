@model DroneComponentsInventory.Models.FCComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Dzēst lidojuma kontrolieri</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/fc.css" />
</head>
<body class="is-preload">

    <div class="fc-panel">

        <h3 style="margin-top: 0;">
            Dzēst lidojuma kontrolieri
        </h3>

        <p>
            Vai tiešām vēlaties dzēst šo lidojuma kontrolieri?
            <strong>Šo darbību nevar atsaukt.</strong>
        </p>

        <hr />

        <dl class="fc-meta">

            <dt>Ražotājs</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Modelis</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Procesors</dt>
            <dd>@Html.DisplayFor(m => m.McuProcessor)</dd>

            <dt>IMU / Žiroskops</dt>
            <dd>@Html.DisplayFor(m => m.ImuGyro)</dd>

            <dt>Montāžas pinums (mm)</dt>
            <dd>@Html.DisplayFor(m => m.MountPatternMm)</dd>

            <dt>Sprieguma ieeja (S)</dt>
            <dd>@Html.DisplayFor(m => m.VoltageInputS)</dd>

            <dt>Programmatūras atbalsts</dt>
            <dd>@Html.DisplayFor(m => m.FirmwareSupport)</dd>

            <dt>Svars (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="FcId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Atcelt
                </a>

                <input type="submit"
                       value="Dzēst"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>