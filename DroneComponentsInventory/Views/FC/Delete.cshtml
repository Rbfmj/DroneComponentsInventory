@model DroneComponentsInventory.Models.FCComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete Flight Controller</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/fc.css" />
</head>
<body class="is-preload">

    <div class="fc-panel">

        <h3 style="margin-top: 0;">
            Delete Flight Controller
        </h3>

        <p>
            Are you sure you want to delete this flight controller?
            <strong>This action cannot be undone.</strong>
        </p>

        <hr />

        <dl class="fc-meta">

            <dt>Manufacturer</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Model</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Processor</dt>
            <dd>@Html.DisplayFor(m => m.McuProcessor)</dd>

            <dt>IMU / Gyro</dt>
            <dd>@Html.DisplayFor(m => m.ImuGyro)</dd>

            <dt>Mount Pattern (mm)</dt>
            <dd>@Html.DisplayFor(m => m.MountPatternMm)</dd>

            <dt>Voltage Input (S)</dt>
            <dd>@Html.DisplayFor(m => m.VoltageInputS)</dd>

            <dt>Firmware Support</dt>
            <dd>@Html.DisplayFor(m => m.FirmwareSupport)</dd>

            <dt>Weight (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="FcId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Cancel
                </a>

                <input type="submit"
                       value="Delete"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>