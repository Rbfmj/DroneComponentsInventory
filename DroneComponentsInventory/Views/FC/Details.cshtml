@model DroneComponentsInventory.Models.FCComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/fc.css" />
</head>
<body class="is-preload">

    <div class="fc-panel">
        <h2>Flight Controller Details</h2>
        <hr />
        <dl class="fc-meta">
            <dt>Manufacturer</dt>
            <dd>@Html.DisplayFor(model => model.Manufacturer)</dd>

            <dt>Model</dt>
            <dd>@Html.DisplayFor(model => model.Model)</dd>

            <dt>Processor</dt>
            <dd>@Html.DisplayFor(model => model.McuProcessor)</dd>

            <dt>IMU / Gyro</dt>
            <dd>@Html.DisplayFor(model => model.ImuGyro)</dd>

            <dt>Mount Pattern (mm)</dt>
            <dd>@Html.DisplayFor(model => model.MountPatternMm)</dd>

            <dt>Voltage Input</dt>
            <dd>@Html.DisplayFor(model => model.VoltageInputS)</dd>

            <dt>Firmware Support</dt>
            <dd>@Html.DisplayFor(model => model.FirmwareSupport)</dd>

            <dt>Weight (g)</dt>
            <dd>@Html.DisplayFor(model => model.WeightG)</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(model => model.Price)</dd>
        </dl>

        
        <!-- =====================================================
             ACTION BUTTONS
             ===================================================== -->
        <div style="margin-top: 12px; display: flex; gap: 8px;">

            <a asp-action="Edit"
                   asp-route-id="@Model?.FcId"
                   class="button small">
                Edit
            </a>

            <a asp-action="Delete"
                   asp-route-id="@Model?.FcId"
                   class="button small">
                Delete
            </a>

            <a asp-action="Index"
                   class="button small">
                Back to List
            </a>

        </div>
    </div>

</body>
</html>
