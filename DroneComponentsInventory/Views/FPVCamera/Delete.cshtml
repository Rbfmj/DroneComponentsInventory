@model DroneComponentsInventory.Models.FPVCameraComponent

@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Dzēst FPV kameru</title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/fpvcamera.css" />
</head>
<body class="is-preload">
    <div class="fpvcamera-panel">
        <h3 style="margin-top: 0;">
            Dzēst FPV kameru
        </h3>
        <p>
            Vai tiešām vēlaties dzēst šo kameru?
            <strong>Šo darbību nevar atsaukt.</strong>
        </p>
        <hr />

        <dl class="fpvcamera-meta">

            <dt>Ražotājs</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Modelis</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Sistēmas tips</dt>
            <dd>@Html.DisplayFor(m => m.TypeSystem)</dd>

            <dt>Sensoru izmērs</dt>
            <dd>@Html.DisplayFor(m => m.SensorSize)</dd>

            <dt>Izšķirtspēja (TVL)</dt>
            <dd>@Html.DisplayFor(m => m.ResolutionTvl)</dd>

            <dt>Skata leņķis (FOV)</dt>
            <dd>@Html.DisplayFor(m => m.FovModes)</dd>

            <dt>Objektīva fokusa attālums (mm)</dt>
            <dd>@Html.DisplayFor(m => m.LensFocalMm)</dd>

            <dt>Attiecības attiecības</dt>
            <dd>@Html.DisplayFor(m => m.SupportedAspectRatios)</dd>

            <dt>Zema apgaismojuma novērtējums (Lux)</dt>
            <dd>@Html.DisplayFor(m => m.LowLightLux)</dd>

            <dt>Montāžas izmērs (mm)</dt>
            <dd>@Html.DisplayFor(m => m.MountSizeMm)</dd>

            <dt>Svars (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Cena</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="CameraId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Atcelt
                </a>

                <input type="submit"
                       value="Dzēst"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>