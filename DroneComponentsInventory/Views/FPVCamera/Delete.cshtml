@model DroneComponentsInventory.Models.FPVCameraComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete FPV Camera</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/camera.css" />
</head>
<body class="is-preload">

    <div class="camera-panel">

        <h3 style="margin-top: 0;">
            Delete FPV Camera
        </h3>

        <p>
            Are you sure you want to delete this camera?
            <strong>This action cannot be undone.</strong>
        </p>

        <hr />

        <dl class="camera-meta">

            <dt>Manufacturer</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Model</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>System Type</dt>
            <dd>@Html.DisplayFor(m => m.TypeSystem)</dd>

            <dt>Sensor Size</dt>
            <dd>@Html.DisplayFor(m => m.SensorSize)</dd>

            <dt>Resolution (TVL)</dt>
            <dd>@Html.DisplayFor(m => m.ResolutionTvl)</dd>

            <dt>Field of View (FOV)</dt>
            <dd>@Html.DisplayFor(m => m.FovModes)</dd>

            <dt>Lens Focal Length (mm)</dt>
            <dd>@Html.DisplayFor(m => m.LensFocalMm)</dd>

            <dt>Aspect Ratios</dt>
            <dd>@Html.DisplayFor(m => m.SupportedAspectRatios)</dd>

            <dt>Low Light Rating (Lux)</dt>
            <dd>@Html.DisplayFor(m => m.LowLightLux)</dd>

            <dt>Mounting Size (mm)</dt>
            <dd>@Html.DisplayFor(m => m.MountSizeMm)</dd>

            <dt>Weight (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="CameraId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Cancel
                </a>

                <input type="submit"
                       value="Delete"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>