@model IEnumerable<DroneComponentsInventory.Models.FPVCameraComponent>

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
</head>
<body>
<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Manufacturer)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Model)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TypeSystem)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SensorSize)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ResolutionTvl)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.FovModes)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LensFocalMm)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SupportedAspectRatios)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LowLightLux)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.WeightG)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MountSizeMm)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Manufacturer)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Model)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TypeSystem)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SensorSize)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ResolutionTvl)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FovModes)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LensFocalMm)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SupportedAspectRatios)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LowLightLux)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.WeightG)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.MountSizeMm)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.CameraId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.CameraId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.CameraId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
</body>
</html>
