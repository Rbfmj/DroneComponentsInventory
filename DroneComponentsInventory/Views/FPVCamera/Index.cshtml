@model IEnumerable<DroneComponentsInventory.Models.FPVCameraComponent>
@using System.Linq

@{
    /* This view is rendered standalone (no shared layout) */
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Kameras</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/fpvcamera.css" />
</head>

<body class="is-preload">

    <partial name="_IndexQuickNav" />

    <div class="fpvcamera-view">

        <div class="wrapper style1 align-center">
            <div class="inner">
                <h2>Kameras</h2>
                <p>Izvēlieties kameru, lai skatītu tehnisko specifikāciju.</p>

                <p>
                    <a asp-action="Create" class="button small">Pievienot jaunu kameru</a>
                </p>
            </div>
        </div>

        <div class="wrapper">
            <div class="inner">
                <div class="fpvcamera-grid" id="fpvcameraGrid">
                    @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.FPVCameraComponent>())
                    {
                        <article class="fpvcamera-tile" data-modal-id="cmodal-@item.CameraId">
                            <div>
                                <span class="title">@item.Manufacturer</span>
                                <span class="muted">@item.Model</span>
                            </div>
                        </article>
                    }
                </div>
            </div>
        </div>

        @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.FPVCameraComponent>())
        {
            <div id="cmodal-@item.CameraId" class="fpvcamera-modal" style="display:none;" aria-hidden="true">
                <div class="panel">
                    <button type="button" class="button small close-modal" style="position:absolute; right:12px; top:12px;">×</button>

                    <h2>@item.Manufacturer @item.Model</h2>

                    <dl class="fpvcamera-meta">
                        <dt>Tips / sistēma</dt>
                        <dd>@item.TypeSystem</dd>

                        <dt>Sensoru izmērs</dt>
                        <dd>@item.SensorSize</dd>

                        <dt>Izšķirtspēja</dt>
                        <dd>@(item.ResolutionTvl?.ToString() + " TVL" ?? "")</dd>

                        <dt>FOV režīmi</dt>
                        <dd>@item.FovModes</dd>

                        <dt>Objektīvs</dt>
                        <dd>@(item.LensFocalMm?.ToString() + " mm" ?? "")</dd>

                        <dt>Attiecību aspekti</dt>
                        <dd>@item.SupportedAspectRatios</dd>

                        <dt>Sensitivitāte vāja apgaismojuma apstākļos</dt>
                        <dd>@(item.LowLightLux?.ToString() ?? "")</dd>

                        <dt>Svars</dt>
                        <dd>@(item.WeightG?.ToString() + " g" ?? "")</dd>

                        <dt>Montāžas izmērs</dt>
                        <dd>@(item.MountSizeMm?.ToString() + " mm" ?? "")</dd>

                        <dt>Cena</dt>
                        <dd>@item.Price</dd>
                    </dl>

                    <div style="margin-top:16px; display:flex; gap:12px; justify-content:flex-end;">
                        <a class="button small" asp-action="Edit" asp-route-id="@item.CameraId">Rediģēt</a>
                        <a class="button small" asp-action="Details" asp-route-id="@item.CameraId">Detalizēti</a>
                        <a class="button small danger" asp-action="Delete" asp-route-id="@item.CameraId">Dzēst</a>
                        <button type="button" class="button small close-modal">Aizvērt</button>
                    </div>
                </div>
            </div>
        }

    </div>

    <script src="/js/fpvcamera-modals.js"></script>

</body>
</html>
