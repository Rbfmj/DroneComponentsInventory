@model DroneComponentsInventory.Models.FPVCameraComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/fpvcamera.css" />
</head>
<body class="is-preload">
    <div class="fpvcamera-panel">
        <h2>@Model.Manufacturer @Model.Model</h2>
        <hr />
        <dl class="fpvcamera-meta">
            <dt>Tips / Sistēma</dt>
            <dd>@Html.DisplayFor(model => model.TypeSystem)</dd>

            <dt>Sensoru izmērs</dt>
            <dd>@Html.DisplayFor(model => model.SensorSize)</dd>

            <dt>Izšķirtspēja (TVL)</dt>
            <dd>@Html.DisplayFor(model => model.ResolutionTvl)</dd>

            <dt>FOV režīmi</dt>
            <dd>@Html.DisplayFor(model => model.FovModes)</dd>

            <dt>Objektīva fokuss (mm)</dt>
            <dd>@Html.DisplayFor(model => model.LensFocalMm)</dd>

            <dt>Apkopes atbalstītās aspektu attiecības</dt>
            <dd>@Html.DisplayFor(model => model.SupportedAspectRatios)</dd>

            <dt>Zema apgaismojuma prasības (lux)</dt>
            <dd>@Html.DisplayFor(model => model.LowLightLux)</dd>

            <dt>Svars (g)</dt>
            <dd>@Html.DisplayFor(model => model.WeightG)</dd>

            <dt>Montāžas izmērs (mm)</dt>
            <dd>@Html.DisplayFor(model => model.MountSizeMm)</dd>

            <dt>Cena</dt>
            <dd>@Html.DisplayFor(model => model.Price)</dd>
        </dl>

        
        <!-- =====================================================
             AKCIJAS POGAS
             ===================================================== -->
        <div style="margin-top: 12px; display: flex; gap: 8px;">

            <a asp-action="Edit"
                   asp-route-id="@Model?.CameraId"
                   class="button small">
                Rediģēt
            </a>

            <a asp-action="Delete"
                   asp-route-id="@Model?.CameraId"
                   class="button small">
                Dzēst
            </a>

            <a asp-action="Index"
                   class="button small">
                Atpakaļ uz sarakstu
            </a>

        </div>
    </div>

</body>
</html>
