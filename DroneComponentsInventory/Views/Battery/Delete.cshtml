@model DroneComponentsInventory.Models.BatteryComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Responsive viewport -->
    <meta name="viewport" content="width=device-width" />

    <!-- Core site styles -->
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/battery.css" />
</head>

<body class="is-preload">

    <!-- =========================================================
         BATTERY DELETE CONFIRMATION
         ========================================================= -->
    <div class="battery-panel">

        <!-- Page heading -->
        <h3 style="margin-top: 0;">
            Delete Battery
        </h3>

        <!-- Warning message -->
        <p>
            Are you sure you want to delete this battery?
            <strong>This action cannot be undone.</strong>
        </p>

        <hr />

        <!-- =====================================================
             BATTERY SUMMARY (READ-ONLY)
             ===================================================== -->
        <dl class="battery-meta">

            <dt>Manufacturer</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Model</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Cell Count (S)</dt>
            <dd>@Html.DisplayFor(m => m.CellCountS)</dd>

            <dt>Nominal Voltage</dt>
            <dd>@Html.DisplayFor(m => m.NominalVoltageV)</dd>

            <dt>Capacity (mAh)</dt>
            <dd>@Html.DisplayFor(m => m.CapacityMah)</dd>

            <dt>Discharge Rate (C)</dt>
            <dd>@Html.DisplayFor(m => m.DischargeRateC)</dd>

            <dt>Burst Rate (C)</dt>
            <dd>@Html.DisplayFor(m => m.BurstRateC)</dd>

            <dt>Discharge Connector</dt>
            <dd>@Html.DisplayFor(m => m.DischargeConnector)</dd>

            <dt>Balance Connector</dt>
            <dd>@Html.DisplayFor(m => m.BalanceConnector)</dd>

            <dt>Chemistry</dt>
            <dd>@Html.DisplayFor(m => m.Chemistry)</dd>

            <dt>Weight (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Length</dt>
            <dd>@Html.DisplayFor(m => m.LengthMm)</dd>

            <dt>Width</dt>
            <dd>@Html.DisplayFor(m => m.WidthMm)</dd>

            <dt>Height</dt>
            <dd>@Html.DisplayFor(m => m.HeightMm)</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <!-- =====================================================
             DELETE FORM ACTIONS
             ===================================================== -->
        <form asp-action="Delete">

            <!-- Hidden primary key -->
            <input type="hidden"
                   asp-for="BatteryId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Cancel
                </a>

                <input type="submit"
                       value="Delete"
                       class="button small danger" />

            </div>

        </form>

    </div>

</body>
</html>