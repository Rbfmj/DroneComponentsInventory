@model DroneComponentsInventory.Models.BatteryComponent

@{
    /* Patstāvīga skata iestatījumi – nav kopīgas izkārtojuma */
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <!-- Reaģējoša skata saskarne -->
    <meta name="viewport" content="width=device-width" />

    <!-- Galvenie vietnes stili -->
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/battery.css" />
</head>

<body class="is-preload">

    <!-- =========================================================
         AKUMULATORA DZĒŠANAS APSTIPRINĀJUMS
         ========================================================= -->
    <div class="battery-panel">

        <!-- Lappuses virsraksts -->
        <h3 style="margin-top: 0;">
            Dzēst akumulatoru
        </h3>

        <!-- Brīdinājuma ziņojums -->
        <p>
            Vai tiešām vēlaties dzēst šo akumulatoru?
            <strong>Šo darbību nevar atsaukt.</strong>
        </p>

        <hr />

        <!-- =====================================================
             AKUMULATORA KOPSAVILKUMS (TIKAI LASĪŠANAI)
             ===================================================== -->
        <dl class="battery-meta">

            <dt>Ražotājs</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Modelis</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Elemntu skaits (S)</dt>
            <dd>@Html.DisplayFor(m => m.CellCountS)</dd>

            <dt>Nominālā sprieguma</dt>
            <dd>@Html.DisplayFor(m => m.NominalVoltageV)</dd>

            <dt>Kapacitāte (mAh)</dt>
            <dd>@Html.DisplayFor(m => m.CapacityMah)</dd>

            <dt>Izlādes ātrums (C)</dt>
            <dd>@Html.DisplayFor(m => m.DischargeRateC)</dd>

            <dt>Strāvas spikes (C)</dt>
            <dd>@Html.DisplayFor(m => m.BurstRateC)</dd>

            <dt>Izlādes savienotājs</dt>
            <dd>@Html.DisplayFor(m => m.DischargeConnector)</dd>

            <dt>Balansa savienotājs</dt>
            <dd>@Html.DisplayFor(m => m.BalanceConnector)</dd>

            <dt>Ķīmija</dt>
            <dd>@Html.DisplayFor(m => m.Chemistry)</dd>

            <dt>Svars (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Garums</dt>
            <dd>@Html.DisplayFor(m => m.LengthMm)</dd>

            <dt>Platums</dt>
            <dd>@Html.DisplayFor(m => m.WidthMm)</dd>

            <dt>Augstums</dt>
            <dd>@Html.DisplayFor(m => m.HeightMm)</dd>

            <dt> cena</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <!-- =====================================================
             DZĒŠANAS FORMA
             ===================================================== -->
        <form asp-action="Delete">

            <!-- Slēptā primārā atslēga -->
            <input type="hidden"
                   asp-for="BatteryId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Atcelt
                </a>

                <input type="submit"
                       value="Izdzēst"
                       class="button small danger" />

            </div>

        </form>

    </div>

</body>
</html>