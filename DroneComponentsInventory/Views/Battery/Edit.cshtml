@model DroneComponentsInventory.Models.BatteryComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <!-- Responsive viewport -->
    <meta name="viewport" content="width=device-width" />

    <!-- Core site styles -->
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/battery.css" />
</head>

<body class="is-preload">

    <!-- =========================================================
         BATTERY EDIT PANEL
         ========================================================= -->
    <div class="battery-panel">

        <!-- Page heading -->
        <h2>Rediģēt akumulatoru</h2>

        <!-- =====================================================
             EDIT FORM
             ===================================================== -->
        <form asp-action="Edit">

            <!-- Model-level validation errors -->
            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <!-- Hidden primary key (required for updates) -->
            <input type="hidden"
                   asp-for="BatteryId" />

            <!-- =================================================
                 FORM GRID
                 ================================================= -->
            <div class="form-grid">

                <!-- Manufacturer -->
                <div class="form-group">
                    <label asp-for="Manufacturer" class="control-label">
                        Ražotājs
                    </label>

                    <input asp-for="Manufacturer"
                           class="form-control" />

                    <span asp-validation-for="Manufacturer"
                          class="text-danger">
                    </span>
                </div>

                <!-- Model -->
                <div class="form-group">
                    <label asp-for="Model" class="control-label">
                        Modelis
                    </label>

                    <input asp-for="Model"
                           class="form-control" />

                    <span asp-validation-for="Model"
                          class="text-danger">
                    </span>
                </div>

                <!-- Cell Count -->
                <div class="form-group">
                    <label asp-for="CellCountS" class="control-label">
                        Šūnu skaits (S)
                    </label>

                    <input asp-for="CellCountS"
                           class="form-control"
                           type="number" />

                    <span asp-validation-for="CellCountS"
                          class="text-danger">
                    </span>
                </div>

                <!-- Nominal Voltage -->
                <div class="form-group">
                    <label asp-for="NominalVoltageV" class="control-label">
                        Nosacītā spriegums (V)
                    </label>

                    <input asp-for="NominalVoltageV"
                           class="form-control"
                           type="number"
                           step="any" />

                    <span asp-validation-for="NominalVoltageV"
                          class="text-danger">
                    </span>
                </div>

                <!-- Capacity -->
                <div class="form-group">
                    <label asp-for="CapacityMah" class="control-label">
                        Ietilpība (mAh)
                    </label>

                    <input asp-for="CapacityMah"
                           class="form-control"
                           type="number" />

                    <span asp-validation-for="CapacityMah"
                          class="text-danger">
                    </span>
                </div>

                <!-- Discharge Rate -->
                <div class="form-group">
                    <label asp-for="DischargeRateC" class="control-label">
                        Izlādes ātrums (C)
                    </label>

                    <input asp-for="DischargeRateC"
                           class="form-control"
                           type="number"
                           step="any" />

                    <span asp-validation-for="DischargeRateC"
                          class="text-danger">
                    </span>
                </div>

                <!-- Burst Rate -->
                <div class="form-group">
                    <label asp-for="BurstRateC" class="control-label">
                        Pārtraukuma ātrums (C)
                    </label>

                    <input asp-for="BurstRateC"
                           class="form-control"
                           type="number"
                           step="any" />

                    <span asp-validation-for="BurstRateC"
                          class="text-danger">
                    </span>
                </div>

                <!-- Discharge Connector -->
                <div class="form-group">
                    <label asp-for="DischargeConnector" class="control-label">
                        Izlādes savienotājs
                    </label>

                    <input asp-for="DischargeConnector"
                           class="form-control" />

                    <span asp-validation-for="DischargeConnector"
                          class="text-danger">
                    </span>
                </div>

                <!-- Balance Connector -->
                <div class="form-group">
                    <label asp-for="BalanceConnector" class="control-label">
                        Balansa savienotājs
                    </label>

                    <input asp-for="BalanceConnector"
                           class="form-control" />

                    <span asp-validation-for="BalanceConnector"
                          class="text-danger">
                    </span>
                </div>

                <!-- Chemistry -->
                <div class="form-group">
                    <label asp-for="Chemistry" class="control-label">
                        Ķīmija
                    </label>

                    <input asp-for="Chemistry"
                           class="form-control" />

                    <span asp-validation-for="Chemistry"
                          class="text-danger">
                    </span>
                </div>

                <!-- Weight -->
                <div class="form-group">
                    <label asp-for="WeightG" class="control-label">
                        Svars (g)
                    </label>

                    <input asp-for="WeightG"
                           class="form-control"
                           type="number"
                           step="1" />

                    <span asp-validation-for="WeightG"
                          class="text-danger">
                    </span>
                </div>

                <!-- Length -->
                <div class="form-group">
                    <label asp-for="LengthMm" class="control-label">
                        Garums (mm)
                    </label>

                    <input asp-for="LengthMm"
                           class="form-control"
                           type="number"
                           step="1" />

                    <span asp-validation-for="LengthMm"
                          class="text-danger">
                    </span>
                </div>

                <!-- Width -->
                <div class="form-group">
                    <label asp-for="WidthMm" class="control-label">
                        Platums (mm)
                    </label>

                    <input asp-for="WidthMm"
                           class="form-control"
                           type="number"
                           step="1" />

                    <span asp-validation-for="WidthMm"
                          class="text-danger">
                    </span>
                </div>

                <!-- Height -->
                <div class="form-group">
                    <label asp-for="HeightMm" class="control-label">
                        Augstums (mm)
                    </label>

                    <input asp-for="HeightMm"
                           class="form-control"
                           type="number"
                           step="1" />

                    <span asp-validation-for="HeightMm"
                          class="text-danger">
                    </span>
                </div>

                <!-- Price -->
                <div class="form-group">
                    <label asp-for="Price" class="control-label">
                        Cena
                    </label>

                    <input asp-for="Price"
                           class="form-control"
                           type="number"
                           step="0.01" />

                    <span asp-validation-for="Price"
                          class="text-danger">
                    </span>
                </div>

            </div>

            <!-- =================================================
                 FORM ACTIONS
                 ================================================= -->
            <div style="margin-top: 12px; display: flex; gap: 8px;">

                <input type="submit"
                       value="Saglabāt"
                       class="button small" />

                <a asp-action="Index"
                       class="button small">
                    Atcelt
                </a>
            </div>

        </form>
    </div>

</body>
</html>