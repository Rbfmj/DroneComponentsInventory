@model IEnumerable<DroneComponentsInventory.Models.RadioControllerComponent>
@using System.Linq

@{
    /* This view is rendered standalone (no shared layout) */
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <!-- Basic responsive meta -->
    <meta name="viewport" content="width=device-width" />

    <title>Radio Kontrolieris</title>

    <!-- Core site styles -->
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/radiocontrollers.css" />
</head>

<body class="is-preload">

    <partial name="_IndexQuickNav" />

    <div class="radiocontrollers-view">

        <div class="wrapper style1 align-center">
            <div class="inner">
                <h2>Radio Kontrolieri</h2>

                <p>Izvēlieties radio kontrolieri, lai skatītu tehnisko specifikāciju.</p>

                <p>
                    <a asp-action="Create" class="button small">Pievienot jaunu radio kontrolieri</a>
                </p>
            </div>
        </div>

        <div class="wrapper">
            <div class="inner">

                <div class="radiocontrollers-grid" id="radiocontrollersGrid">

                    @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.RadioControllerComponent>())
                    {
                        <article class="radiocontrollers-tile" data-modal-id="rcmodal-@item.RadioControllerId">
                            <div>
                                <span class="title">@item.Manufacturer</span>
                                <span class="muted">@item.Model</span>
                            </div>
                        </article>
                    }

                </div>

            </div>
        </div>

        @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.RadioControllerComponent>())
        {
            <div id="rcmodal-@item.RadioControllerId" class="radiocontrollers-modal" style="display:none;" aria-hidden="true">
                <div class="panel">

                    <button type="button" class="button small close-modal" style="position:absolute; right:12px; top:12px;">×</button>

                    <h2>@item.Manufacturer @item.Model</h2>

                    <dl class="radiocontrollers-meta">
                        <dt>Stils</dt>
                        <dd>@item.ControllerStyle</dd>

                        <dt>Frekvence</dt>
                        <dd>@(item.FrequencyGhz?.ToString("0.0") + " GHz" ?? "")</dd>

                        <dt>Atbalstītie protokoli</dt>
                        <dd>@item.ProtocolsSupported</dd>

                        <dt>Maks. kanāli</dt>
                        <dd>@item.MaxChannels</dd>

                        <dt>Jauda</dt>
                        <dd>@(item.OutputPowerMw?.ToString() + " mW" ?? "")</dd>

                        <dt>Telemetrijas atbalsts</dt>
                        <dd>@(item.TelemetrySupport ? "Jā" : "Nē")</dd>

                        <dt>Ekraņa tips</dt>
                        <dd>@item.ScreenType</dd>

                        <dt>Stabilizatora tips</dt>
                        <dd>@item.GimbalType</dd>

                        <dt>Akkumulatora tips</dt>
                        <dd>@item.BatteryType</dd>

                        <dt>Svars</dt>
                        <dd>@(item.WeightG?.ToString() + " g" ?? "")</dd>

                        <dt>Programmatūras atbalsts</dt>
                        <dd>@item.FirmwareSupport</dd>

                        <dt>Cena</dt>
                        <dd>@(item.Price.HasValue? item.Price.Value.ToString("0.00") : "")</dd>
                    </dl>

                    <div style="margin-top:16px; display:flex; gap:12px; justify-content:flex-end;">
                        <a class="button small" asp-action="Edit" asp-route-id="@item.RadioControllerId">Rediģēt</a>
                        <a class="button small" asp-action="Details" asp-route-id="@item.RadioControllerId">Sīkāk</a>
                        <a class="button small danger" asp-action="Delete" asp-route-id="@item.RadioControllerId">Dzēst</a>
                        <button type="button" class="button small close-modal">Aizvērt</button>
                    </div>

                </div>
            </div>
        }

    </div>

    <script src="/js/radiocontrollers-modals.js"></script>

</body>
</html>