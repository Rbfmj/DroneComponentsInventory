@model DroneComponentsInventory.Models.RadioControllerComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Radio pults detaļas</title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/radiocontrollers.css" />
</head>
<body class="is-preload">
    <div class="radiocontrollers-panel">
        <h2>@Model.Manufacturer @Model.Model</h2>
        <dl class="radiocontrollers-meta">
            <dt>Stils</dt>
            <dd>@(Model.ControllerStyle ?? "—")</dd>

            <dt>Frekvence</dt>
            <dd>@(Model.FrequencyGhz?.ToString("0.0") + " GHz" ?? "—")</dd>

            <dt>Atbalstītie protokoli</dt>
            <dd>@(Model.ProtocolsSupported ?? "—")</dd>

            <dt>Maks. kanāli</dt>
            <dd>@(Model.MaxChannels?.ToString() ?? "—")</dd>

            <dt>Jauda</dt>
            <dd>@(Model.OutputPowerMw?.ToString() + " mW" ?? "—")</dd>

            <dt>Telemetrijas atbalsts</dt>
            <dd>@(Model.TelemetrySupport ? "Jā" : "Nē")</dd>

            <dt>Ekrāna tips</dt>
            <dd>@(Model.ScreenType ?? "—")</dd>

            <dt>Gimbal tips</dt>
            <dd>@(Model.GimbalType ?? "—")</dd>

            <dt>Baterijas tips</dt>
            <dd>@(Model.BatteryType ?? "—")</dd>

            <dt>Svars</dt>
            <dd>@(Model.WeightG?.ToString() + " g" ?? "—")</dd>

            <dt>Programmatūras atbalsts</dt>
            <dd>@(Model.FirmwareSupport ?? "—")</dd>

            <dt>Cena</dt>
            <dd>@(Model.Price.HasValue ? "$" + Model.Price.Value.ToString("0.00") : "—")</dd>
        </dl>

        
        <!-- =====================================================
             ACTION BUTTONS
             ===================================================== -->
        <div style="margin-top: 12px; display: flex; gap: 8px;">

            <a asp-action="Edit"
                   asp-route-id="@Model?.RadioControllerId"
                   class="button small">
                Rediģēt
            </a>

            <a asp-action="Delete"
                   asp-route-id="@Model?.RadioControllerId"
                   class="button small">
                Dzēst
            </a>

            <a asp-action="Index"
                   class="button small">
                Atpakaļ uz sarakstu
            </a>

        </div>

    </div>

</body>
</html>