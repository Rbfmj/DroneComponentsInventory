@model DroneComponentsInventory.Models.RadioControllerComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Radio Controller Details</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/radiocontrollers.css" />
</head>

<body class="is-preload">

    <div class="radiocontrollers-panel">

        <h2>@Model.Manufacturer @Model.Model</h2>

        <dl class="radiocontrollers-meta">
            <dt>Style</dt>
            <dd>@(Model.ControllerStyle ?? "—")</dd>

            <dt>Frequency</dt>
            <dd>@(Model.FrequencyGhz?.ToString("0.0") + " GHz" ?? "—")</dd>

            <dt>Protocols Supported</dt>
            <dd>@(Model.ProtocolsSupported ?? "—")</dd>

            <dt>Max Channels</dt>
            <dd>@(Model.MaxChannels?.ToString() ?? "—")</dd>

            <dt>Output Power</dt>
            <dd>@(Model.OutputPowerMw?.ToString() + " mW" ?? "—")</dd>

            <dt>Telemetry Support</dt>
            <dd>@(Model.TelemetrySupport ? "Yes" : "No")</dd>

            <dt>Screen Type</dt>
            <dd>@(Model.ScreenType ?? "—")</dd>

            <dt>Gimbal Type</dt>
            <dd>@(Model.GimbalType ?? "—")</dd>

            <dt>Battery Type</dt>
            <dd>@(Model.BatteryType ?? "—")</dd>

            <dt>Weight</dt>
            <dd>@(Model.WeightG?.ToString() + " g" ?? "—")</dd>

            <dt>Firmware Support</dt>
            <dd>@(Model.FirmwareSupport ?? "—")</dd>

            <dt>Price</dt>
            <dd>@(Model.Price.HasValue ? "$" + Model.Price.Value.ToString("0.00") : "—")</dd>
        </dl>

        
        <!-- =====================================================
             ACTION BUTTONS
             ===================================================== -->
        <div style="margin-top: 12px; display: flex; gap: 8px;">

            <a asp-action="Edit"
                   asp-route-id="@Model?.RadioControllerId"
                   class="button small">
                Edit
            </a>

            <a asp-action="Delete"
                   asp-route-id="@Model?.RadioControllerId"
                   class="button small">
                Delete
            </a>

            <a asp-action="Index"
                   class="button small">
                Back to List
            </a>

        </div>

    </div>

</body>
</html>