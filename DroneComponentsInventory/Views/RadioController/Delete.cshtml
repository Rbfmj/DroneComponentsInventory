@model DroneComponentsInventory.Models.RadioControllerComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete Radio Controller</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/radiocontrollers.css" />
</head>
<body class="is-preload">

    <div class="radiocontrollers-panel">

        <h3 style="margin-top: 0;">
            Delete Radio Controller
        </h3>

        <p>
            Are you sure you want to delete this radio controller?
            <strong>This action cannot be undone.</strong>
        </p>

        <hr />

        <dl class="radiocontrollers-meta">

            <dt>Manufacturer</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Model</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Style</dt>
            <dd>@Html.DisplayFor(m => m.ControllerStyle)</dd>

            <dt>Frequency (GHz)</dt>
            <dd>@Html.DisplayFor(m => m.FrequencyGhz)</dd>

            <dt>Protocols</dt>
            <dd>@Html.DisplayFor(m => m.ProtocolsSupported)</dd>

            <dt>Max Channels</dt>
            <dd>@Html.DisplayFor(m => m.MaxChannels)</dd>

            <dt>Output Power (mW)</dt>
            <dd>@Html.DisplayFor(m => m.OutputPowerMw)</dd>

            <dt>Telemetry Support</dt>
            <dd>@(Model.TelemetrySupport ? "Yes" : "No")</dd>

            <dt>Screen Type</dt>
            <dd>@Html.DisplayFor(m => m.ScreenType)</dd>

            <dt>Gimbal Type</dt>
            <dd>@Html.DisplayFor(m => m.GimbalType)</dd>

            <dt>Battery Type</dt>
            <dd>@Html.DisplayFor(m => m.BatteryType)</dd>

            <dt>Firmware</dt>
            <dd>@Html.DisplayFor(m => m.FirmwareSupport)</dd>

            <dt>Weight (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="RadioControllerId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Cancel
                </a>

                <input type="submit"
                       value="Delete"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>