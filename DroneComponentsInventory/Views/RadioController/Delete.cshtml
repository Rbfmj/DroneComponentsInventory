@model DroneComponentsInventory.Models.RadioControllerComponent

@{
    /* Patstāvīga skats - bez kopīgas izkārtojuma */
    Layout = null;
}
<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Dzēst radio pulti</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/radiocontrollers.css" />
</head>
<body class="is-preload">

    <div class="radiocontrollers-panel">

        <h3 style="margin-top: 0;">
            Dzēst radio pulti
        </h3>

        <p>
            Vai tiešām vēlaties dzēst šo radio pulti?
            <strong>Šo darbību nevar atsaukt.</strong>
        </p>

        <hr />

        <dl class="radiocontrollers-meta">

            <dt>Ražotājs</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Modelis</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Stils</dt>
            <dd>@Html.DisplayFor(m => m.ControllerStyle)</dd>

            <dt>Frequence (GHz)</dt>
            <dd>@Html.DisplayFor(m => m.FrequencyGhz)</dd>

            <dt>Protokoli</dt>
            <dd>@Html.DisplayFor(m => m.ProtocolsSupported)</dd>

            <dt>Maks. kanāli</dt>
            <dd>@Html.DisplayFor(m => m.MaxChannels)</dd>

            <dt>Jauda (mW)</dt>
            <dd>@Html.DisplayFor(m => m.OutputPowerMw)</dd>

            <dt>Telemetrijas atbalsts</dt>
            <dd>@(Model.TelemetrySupport ? "Jā" : "Nē")</dd>

            <dt>Ekraana tips</dt>
            <dd>@Html.DisplayFor(m => m.ScreenType)</dd>

            <dt>Gimbala tips</dt>
            <dd>@Html.DisplayFor(m => m.GimbalType)</dd>

            <dt>Akumulatora tips</dt>
            <dd>@Html.DisplayFor(m => m.BatteryType)</dd>

            <dt>Programmatūra</dt>
            <dd>@Html.DisplayFor(m => m.FirmwareSupport)</dd>

            <dt>Svars (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Cena</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="RadioControllerId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Atcelt
                </a>

                <input type="submit"
                       value="Dzēst"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>