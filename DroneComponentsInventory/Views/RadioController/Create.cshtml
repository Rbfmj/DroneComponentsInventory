@model DroneComponentsInventory.Models.RadioControllerComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Pievienot radio pulti</title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/radiocontrollers.css" />
</head>
<body class="is-preload">
    <div class="radiocontrollers-panel">
        <h2>Pievienot radio pulti</h2>
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="Manufacturer" class="control-label">Ražotājs</label>
                    <input asp-for="Manufacturer" class="form-control" />
                    <span asp-validation-for="Manufacturer" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Model" class="control-label">Modelis</label>
                    <input asp-for="Model" class="form-control" />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ControllerStyle" class="control-label">Pults stils</label>
                    <input asp-for="ControllerStyle" class="form-control" />
                    <span asp-validation-for="ControllerStyle" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="FrequencyGhz" class="control-label">Frekvence (GHz)</label>
                    <input asp-for="FrequencyGhz" class="form-control" type="number" step="0.1" />
                    <span asp-validation-for="FrequencyGhz" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ProtocolsSupported" class="control-label">Atbalstītās protokola</label>
                    <input asp-for="ProtocolsSupported" class="form-control" />
                    <span asp-validation-for="ProtocolsSupported" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MaxChannels" class="control-label">Maks. kanāli</label>
                    <input asp-for="MaxChannels" class="form-control" type="number" step="1" />
                    <span asp-validation-for="MaxChannels" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="OutputPowerMw" class="control-label">Izejas jauda (mW)</label>
                    <input asp-for="OutputPowerMw" class="form-control" type="number" step="1" />
                    <span asp-validation-for="OutputPowerMw" class="text-danger"></span>
                </div>

                <div class="form-group checkbox-group">
                    <label asp-for="TelemetrySupport" class="control-label">Telemetrijas atbalsts</label>
                    <input asp-for="TelemetrySupport" type="checkbox" class="fpv-checkbox" />
                    <span asp-validation-for="TelemetrySupport" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ScreenType" class="control-label">Ekrāna tips</label>
                    <input asp-for="ScreenType" class="form-control" />
                    <span asp-validation-for="ScreenType" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="GimbalType" class="control-label">Gimbala tips</label>
                    <input asp-for="GimbalType" class="form-control" />
                    <span asp-validation-for="GimbalType" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="BatteryType" class="control-label">Akumulatora tips</label>
                    <input asp-for="BatteryType" class="form-control" />
                    <span asp-validation-for="BatteryType" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="WeightG" class="control-label">Svars (g)</label>
                    <input asp-for="WeightG" class="form-control" type="number" step="0.1" />
                    <span asp-validation-for="WeightG" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="FirmwareSupport" class="control-label">Programmatūras atbalsts</label>
                    <input asp-for="FirmwareSupport" class="form-control" />
                    <span asp-validation-for="FirmwareSupport" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Price" class="control-label">Cena</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

            </div>

            <div style="margin-top: 24px; display: flex; gap: 12px;">
                <input type="submit" value="Izveidot" class="button small" />
                <a asp-action="Index" class="button small">Atcelt</a>
            </div>

        </form>

    </div>

</body>
</html>