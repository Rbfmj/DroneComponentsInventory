@model DroneComponentsInventory.Models.VideoTransmitterComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Create FPV Video Transmitter</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/videotransmitters.css" />
</head>

<body class="is-preload">

    <div class="videotransmitters-panel">

        <h2>Create FPV Video Transmitter</h2>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="Manufacturer" class="control-label">Manufacturer</label>
                    <input asp-for="Manufacturer" class="form-control" />
                    <span asp-validation-for="Manufacturer" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Model" class="control-label">Model</label>
                    <input asp-for="Model" class="form-control" />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Type" class="control-label">Type</label>
                    <input asp-for="Type" class="form-control" />
                    <span asp-validation-for="Type" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MaxPowerMw" class="control-label">Max Power (mW)</label>
                    <input asp-for="MaxPowerMw" class="form-control" type="number" step="1" />
                    <span asp-validation-for="MaxPowerMw" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="VoltageInputS" class="control-label">Voltage Input (S)</label>
                    <input asp-for="VoltageInputS" class="form-control" />
                    <span asp-validation-for="VoltageInputS" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="MountPatternMm" class="control-label">Mount Pattern (mm)</label>
                    <input asp-for="MountPatternMm" class="form-control" type="number" step="any" />
                    <span asp-validation-for="MountPatternMm" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ControlProtocols" class="control-label">Control Protocols</label>
                    <input asp-for="ControlProtocols" class="form-control" />
                    <span asp-validation-for="ControlProtocols" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="AntennaConnector" class="control-label">Antenna Connector</label>
                    <input asp-for="AntennaConnector" class="form-control" />
                    <span asp-validation-for="AntennaConnector" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="WeightG" class="control-label">Weight (g)</label>
                    <input asp-for="WeightG" class="form-control" type="number" step="any" />
                    <span asp-validation-for="WeightG" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Price" class="control-label">Price</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

            </div>

            <div style="margin-top: 24px; display: flex; gap: 12px;">
                <input type="submit" value="Create" class="button small" />
                <a asp-action="Index" class="button small">Cancel</a>
            </div>

        </form>

    </div>

</body>
</html>