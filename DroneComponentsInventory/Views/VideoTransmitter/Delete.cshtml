@model DroneComponentsInventory.Models.VideoTransmitterComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete Video Transmitter</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/videotransmitters.css" />
</head>
<body class="is-preload">

    <div class="videotransmitters-panel">

        <h3 style="margin-top: 0;">
            Delete Video Transmitter
        </h3>

        <p>
            Are you sure you want to delete this video transmitter?
            <strong>This action cannot be undone.</strong>
        </p>

        <hr />

        <dl class="videotransmitters-meta">

            <dt>Manufacturer</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Model</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Type</dt>
            <dd>@Html.DisplayFor(m => m.Type)</dd>

            <dt>Max Power (mW)</dt>
            <dd>@Html.DisplayFor(m => m.MaxPowerMw)</dd>

            <dt>Voltage Input (S)</dt>
            <dd>@Html.DisplayFor(m => m.VoltageInputS)</dd>

            <dt>Mount Pattern (mm)</dt>
            <dd>@Html.DisplayFor(m => m.MountPatternMm)</dd>

            <dt>Control Protocols</dt>
            <dd>@Html.DisplayFor(m => m.ControlProtocols)</dd>

            <dt>Antenna Connector</dt>
            <dd>@Html.DisplayFor(m => m.AntennaConnector)</dd>

            <dt>Weight (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="VtxId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Cancel
                </a>

                <input type="submit"
                       value="Delete"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>