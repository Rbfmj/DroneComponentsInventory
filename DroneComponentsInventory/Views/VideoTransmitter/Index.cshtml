@model IEnumerable<DroneComponentsInventory.Models.VideoTransmitterComponent>
@using System.Linq

@{
    /* This view is rendered standalone (no shared layout) */
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <!-- Basic responsive meta -->
    <meta name="viewport" content="width=device-width" />

    <title>Video raidītāji</title>

    <!-- Core site styles -->
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/videotransmitters.css" />
</head>

<body class="is-preload">

    <partial name="_IndexQuickNav" />

    <div class="videotransmitters-view">

        <div class="wrapper style1 align-center">
            <div class="inner">
                <h2>Video raidītāji</h2>

                <p>Izvēlieties video raidītāju, lai skatītu tehnisko specifikāciju.</p>

                <p>
                    <a asp-action="Create" class="button small">Pievienot jaunu video raidītāju</a>
                </p>
            </div>
        </div>

        <div class="wrapper">
            <div class="inner">

                <div class="videotransmitters-grid" id="videotransmittersGrid">

                    @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.VideoTransmitterComponent>())
                    {
                        <article class="videotransmitters-tile" data-modal-id="vtmodal-@item.VtxId">
                            <div>
                                <span class="title">@item.Manufacturer</span>
                                <span class="muted">@item.Model</span>
                            </div>
                        </article>
                    }

                </div>

            </div>
        </div>

        @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.VideoTransmitterComponent>())
        {
            <div id="vtmodal-@item.VtxId" class="videotransmitters-modal" style="display:none;" aria-hidden="true">
                <div class="panel">

                    <button type="button" class="button small close-modal" style="position:absolute; right:12px; top:12px;">×</button>

                    <h2>@item.Manufacturer @item.Model</h2>

                    <dl class="videotransmitters-meta">
                        <dt>Tips</dt>
                        <dd>@item.Type</dd>

                        <dt>Maks. jauda</dt>
                        <dd>@(item.MaxPowerMw?.ToString() + " mW" ?? "")</dd>

                        <dt>Sprieguma ieeja</dt>
                        <dd>@item.VoltageInputS S</dd>

                        <dt>Montāžas raksts</dt>
                        <dd>@(item.MountPatternMm?.ToString() + " mm" ?? "")</dd>

                        <dt>Regulēšanas protokoli</dt>
                        <dd>@item.ControlProtocols</dd>

                        <dt>Antenas savienotājs</dt>
                        <dd>@item.AntennaConnector</dd>

                        <dt>Svars</dt>
                        <dd>@(item.WeightG?.ToString() + " g" ?? "")</dd>

                        <dt>Cena</dt>
                        <dd>@(item.Price.HasValue? item.Price.Value.ToString("0.00") : "")</dd>
                    </dl>

                    <div style="margin-top:16px; display:flex; gap:12px; justify-content:flex-end;">
                        <a class="button small" asp-action="Edit" asp-route-id="@item.VtxId">Rediģēt</a>
                        <a class="button small" asp-action="Details" asp-route-id="@item.VtxId">Detaļas</a>
                        <a class="button small danger" asp-action="Delete" asp-route-id="@item.VtxId">Dzēst</a>
                        <button type="button" class="button small close-modal">Aizvērt</button>
                    </div>

                </div>
            </div>
        }

    </div>

    <script src="/js/videotransmitters-modals.js"></script>

</body>
</html>