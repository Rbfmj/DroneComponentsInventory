@model DroneComponentsInventory.Models.VideoTransmitterComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Video raidītāja detaļas</title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/videotransmitters.css" />
</head>
<body class="is-preload">
    <div class="videotransmitters-panel">
        <h2>@Model.Manufacturer @Model.Model</h2>
        <dl class="videotransmitters-meta">
            <dt>Tips</dt>
            <dd>@(Model.Type ?? "—")</dd>

            <dt>Maks. jauda</dt>
            <dd>@(Model.MaxPowerMw?.ToString() + " mW" ?? "—")</dd>

            <dt>Sprieguma ieeja</dt>
            <dd>@(Model.VoltageInputS?.ToString() + "S" ?? "—")</dd>

            <dt>Piekare</dt>
            <dd>@(Model.MountPatternMm?.ToString() + " mm" ?? "—")</dd>

            <dt>Vadības protokoli</dt>
            <dd>@(Model.ControlProtocols ?? "—")</dd>

            <dt>Antenu savienotājs</dt>
            <dd>@(Model.AntennaConnector ?? "—")</dd>

            <dt>Svars</dt>
            <dd>@(Model.WeightG?.ToString() + " g" ?? "—")</dd>

            <dt>Cena</dt>
            <dd>@(Model.Price.HasValue ? "$" + Model.Price.Value.ToString("0.00") : "—")</dd>
        </dl>

        
        <!-- =====================================================
             ACTION BUTTONS (your new style)
             ===================================================== -->
        <div style="margin-top: 12px; display: flex; gap: 8px;">

            <a asp-action="Edit"
                   asp-route-id="@Model?.VtxId"
                   class="button small">
                Rediģēt
            </a>

            <a asp-action="Delete"
                   asp-route-id="@Model?.VtxId"
                   class="button small">
                Dzēst
            </a>

            <a asp-action="Index"
                   class="button small">
                Atpakaļ uz sarakstu
            </a>

        </div>

    </div>

</body>
</html>