@model DroneComponentsInventory.Models.PropellersComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete Propellers</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/propellers.css" />
</head>
<body class="is-preload">

    <div class="propellers-panel">

        <h3 style="margin-top: 0;">
            Delete Propeller Set
        </h3>

        <p>
            Are you sure you want to delete this propeller set?
            <strong>This action cannot be undone.</strong>
        </p>

        <hr />

        <dl class="propellers-meta">

            <dt>Manufacturer</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Model</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Diameter (mm)</dt>
            <dd>@Html.DisplayFor(m => m.DiameterMm)</dd>

            <dt>Pitch (in)</dt>
            <dd>@Html.DisplayFor(m => m.PitchInch)</dd>

            <dt>Blade Count</dt>
            <dd>@Html.DisplayFor(m => m.BladeCount)</dd>

            <dt>Material</dt>
            <dd>@Html.DisplayFor(m => m.Material)</dd>

            <dt>Shaft Diameter (mm)</dt>
            <dd>@Html.DisplayFor(m => m.ShaftDiameterMm)</dd>

            <dt>Rotation</dt>
            <dd>@Html.DisplayFor(m => m.RotationDirection)</dd>

            <dt>Recommended Motor Size</dt>
            <dd>@Html.DisplayFor(m => m.RecommendedMotorSize)</dd>

            <dt>Recommended Motor KV</dt>
            <dd>@Html.DisplayFor(m => m.RecommendedMotorKv)</dd>

            <dt>Frame Class</dt>
            <dd>@Html.DisplayFor(m => m.FrameClass)</dd>

            <dt>Weight (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Colors Available</dt>
            <dd>@Html.DisplayFor(m => m.ColorOptions)</dd>

            <dt>Quantity Included</dt>
            <dd>@Html.DisplayFor(m => m.IncludedQuantity)</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="PropellerId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Cancel
                </a>

                <input type="submit"
                       value="Delete"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>