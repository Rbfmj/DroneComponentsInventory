@model DroneComponentsInventory.Models.PropellersComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Edit FPV Propellers</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/propellers.css" />
</head>

<body class="is-preload">

    <div class="propellers-panel">

        <h2>Edit FPV Propellers</h2>

        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="PropellerId" />

            <div class="form-grid">
                <!-- Same fields as Create.cshtml above -->
                <div class="form-group">
                    <label asp-for="Manufacturer" class="control-label">Manufacturer</label>
                    <input asp-for="Manufacturer" class="form-control" />
                    <span asp-validation-for="Manufacturer" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Model" class="control-label">Model</label>
                    <input asp-for="Model" class="form-control" />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DiameterMm" class="control-label">Diameter (mm)</label>
                    <input asp-for="DiameterMm" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="DiameterMm" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="PitchInch" class="control-label">Pitch (inch)</label>
                    <input asp-for="PitchInch" class="form-control" type="number" step="any" />
                    <span asp-validation-for="PitchInch" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="BladeCount" class="control-label">Blade Count</label>
                    <input asp-for="BladeCount" class="form-control" type="number" step="1" />
                    <span asp-validation-for="BladeCount" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Material" class="control-label">Material</label>
                    <input asp-for="Material" class="form-control" />
                    <span asp-validation-for="Material" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ShaftDiameterMm" class="control-label">Shaft Diameter (mm)</label>
                    <input asp-for="ShaftDiameterMm" class="form-control" type="number" step="any" />
                    <span asp-validation-for="ShaftDiameterMm" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RotationDirection" class="control-label">Rotation Direction</label>
                    <input asp-for="RotationDirection" class="form-control" />
                    <span asp-validation-for="RotationDirection" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RecommendedMotorSize" class="control-label">Recommended Motor Size</label>
                    <input asp-for="RecommendedMotorSize" class="form-control" />
                    <span asp-validation-for="RecommendedMotorSize" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RecommendedMotorKv" class="control-label">Recommended Motor KV</label>
                    <input asp-for="RecommendedMotorKv" class="form-control" type="number" step="10" />
                    <span asp-validation-for="RecommendedMotorKv" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="FrameClass" class="control-label">Frame Class</label>
                    <input asp-for="FrameClass" class="form-control" />
                    <span asp-validation-for="FrameClass" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="WeightG" class="control-label">Weight (g) per prop</label>
                    <input asp-for="WeightG" class="form-control" type="number" step="any" />
                    <span asp-validation-for="WeightG" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ColorOptions" class="control-label">Color Options</label>
                    <input asp-for="ColorOptions" class="form-control" />
                    <span asp-validation-for="ColorOptions" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="IncludedQuantity" class="control-label">Included Quantity (pcs)</label>
                    <input asp-for="IncludedQuantity" class="form-control" type="number" step="1" />
                    <span asp-validation-for="IncludedQuantity" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Price" class="control-label">Price</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

            </div>

            <div style="margin-top: 24px; display: flex; gap: 12px;">
                <input type="submit" value="Save" class="button small" />
                <a asp-action="Index" class="button small">Cancel</a>
            </div>
        </form>

    </div>

</body>
</html>