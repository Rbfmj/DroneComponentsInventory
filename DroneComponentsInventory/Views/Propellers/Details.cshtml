@model DroneComponentsInventory.Models.PropellersComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Propelleru detaļas</title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/propellers.css" />
</head>
<body class="is-preload">
    <div class="propellers-panel">
        <h2>@Model.Manufacturer @Model.Model</h2>
        <dl class="propellers-meta">
            <dt>Diametrs</dt>
            <dd>@(Model.DiameterMm?.ToString() + " mm" ?? "—")</dd>

            <dt>Solis</dt>
            <dd>@(Model.PitchInch?.ToString() + "\"" ?? "—")</dd>

            <dt>Asu skaits</dt>
            <dd>@(Model.BladeCount?.ToString() ?? "—")</dd>

            <dt>Materiāls</dt>
            <dd>@(Model.Material ?? "—")</dd>

            <dt>Apgriešanās šaftes diametrs</dt>
            <dd>@(Model.ShaftDiameterMm?.ToString() + " mm" ?? "—")</dd>

            <dt>Rotācija</dt>
            <dd>@(Model.RotationDirection ?? "—")</dd>

            <dt> Ieteiktais motors</dt>
            <dd>@(Model.RecommendedMotorSize ?? "—")</dd>

            <dt>Ieteiktais KV</dt>
            <dd>@(Model.RecommendedMotorKv?.ToString() ?? "—")</dd>

            <dt>Rāmja klase</dt>
            <dd>@(Model.FrameClass ?? "—")</dd>

            <dt>Svars (uz propelleri)</dt>
            <dd>@(Model.WeightG?.ToString() + " g" ?? "—")</dd>

            <dt>Krāsas</dt>
            <dd>@(Model.ColorOptions ?? "—")</dd>

            <dt> Iekļauts</dt>
            <dd>@(Model.IncludedQuantity?.ToString() + " gb" ?? "—")</dd>

            <dt>Cena</dt>
            <dd>@(Model.Price.HasValue ? "$" + Model.Price.Value.ToString("0.00") : "—")</dd>
        </dl>

        
        <!-- =====================================================
             ACTION BUTTONS
             ===================================================== -->
        <div style="margin-top: 12px; display: flex; gap: 8px;">

            <a asp-action="Edit"
                   asp-route-id="@Model?.PropellerId"
                   class="button small">
                Rediģēt
            </a>

            <a asp-action="Delete"
                   asp-route-id="@Model?.PropellerId"
                   class="button small">
                Dzēst
            </a>

            <a asp-action="Index"
                   class="button small">
                Atpakaļ uz sarakstu
            </a>

        </div>

    </div>

</body>
</html>