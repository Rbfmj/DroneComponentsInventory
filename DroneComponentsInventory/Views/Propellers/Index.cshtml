@model IEnumerable<DroneComponentsInventory.Models.PropellersComponent>
@using System.Linq

@{
    /* This view is rendered standalone (no shared layout) */
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <!-- Basic responsive meta -->
    <meta name="viewport" content="width=device-width" />

    <title>Propelleri</title>

    <!-- Core site styles -->
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/propellers.css" />
</head>

<body class="is-preload">

    <partial name="_IndexQuickNav" />

    <div class="propellers-view">

        <div class="wrapper style1 align-center">
            <div class="inner">
                <h2>Propelleri</h2>

                <p>Izvēlieties propelleru komplektu, lai skatītu tehnisko specifikāciju.</p>

                <p>
                    <a asp-action="Create" class="button small">Pievienot jaunu propelleru komplektu</a>
                </p>
            </div>
        </div>

        <div class="wrapper">
            <div class="inner">

                <div class="propellers-grid" id="propellersGrid">

                    @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.PropellersComponent>())
                    {
                        <article class="propellers-tile" data-modal-id="prmodal-@item.PropellerId">
                            <div>
                                <span class="title">@item.Manufacturer</span>
                                <span class="muted">@item.Model</span>
                            </div>
                        </article>
                    }

                </div>

            </div>
        </div>

        @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.PropellersComponent>())
        {
            <div id="prmodal-@item.PropellerId" class="propellers-modal" style="display:none;" aria-hidden="true">
                <div class="panel">

                    <button type="button" class="button small close-modal" style="position:absolute; right:12px; top:12px;">×</button>

                    <h2>@item.Manufacturer @item.Model</h2>

                    <dl class="propellers-meta">
                        <dt>Diametrs</dt>
                        <dd>@(item.DiameterMm?.ToString() + " mm" ?? "")</dd>

                        <dt>Solis</dt>
                        <dd>@(item.PitchInch?.ToString() + "\"" ?? "")</dd>

                        <dt>Asu skaits</dt>
                        <dd>@item.BladeCount</dd>

                        <dt>Materiāls</dt>
                        <dd>@item.Material</dd>

                        <dt>Šaftas diametrs</dt>
                        <dd>@(item.ShaftDiameterMm?.ToString() + " mm" ?? "")</dd>

                        <dt>Griezes virziens</dt>
                        <dd>@item.RotationDirection</dd>

                        <dt> Ieteiktais motors</dt>
                        <dd>@item.RecommendedMotorSize</dd>

                        <dt>Ieteiktais KV</dt>
                        <dd>@item.RecommendedMotorKv</dd>

                        <dt>Rāmja klase</dt>
                        <dd>@item.FrameClass</dd>

                        <dt>Svars</dt>
                        <dd>@(item.WeightG?.ToString() + " g" ?? "")</dd>

                        <dt>Krāsas</dt>
                        <dd>@item.ColorOptions</dd>

                        <dt>Iekļauti</dt>
                        <dd>@(item.IncludedQuantity?.ToString() + " pcs" ?? "")</dd>

                        <dt>Цена</dt>
                        <dd>@(item.Price.HasValue? item.Price.Value.ToString("0.00") : "")</dd>
                    </dl>

                    <div style="margin-top:16px; display:flex; gap:12px; justify-content:flex-end;">
                        <a class="button small" asp-action="Edit" asp-route-id="@item.PropellerId">Rediģēt</a>
                        <a class="button small" asp-action="Details" asp-route-id="@item.PropellerId">Detalizēti</a>
                        <a class="button small danger" asp-action="Delete" asp-route-id="@item.PropellerId">Dzēst</a>
                        <button type="button" class="button small close-modal">Aizvērt</button>
                    </div>

                </div>
            </div>
        }

    </div>

    <script src="/js/propellers-modals.js"></script>

</body>
</html>