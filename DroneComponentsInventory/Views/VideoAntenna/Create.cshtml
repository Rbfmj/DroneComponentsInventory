@model DroneComponentsInventory.Models.VideoAntennaComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Create FPV Video Antenna</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/videoantennas.css" />
</head>

<body class="is-preload">

    <div class="videoantennas-panel">

        <h2>Create FPV Video Antenna</h2>

        <form asp-action="Create">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-grid">

                <div class="form-group">
                    <label asp-for="Manufacturer" class="control-label">Manufacturer</label>
                    <input asp-for="Manufacturer" class="form-control" />
                    <span asp-validation-for="Manufacturer" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Model" class="control-label">Model</label>
                    <input asp-for="Model" class="form-control" />
                    <span asp-validation-for="Model" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="AntennaClass" class="control-label">Antenna Class</label>
                    <input asp-for="AntennaClass" class="form-control" />
                    <span asp-validation-for="AntennaClass" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Polarization" class="control-label">Polarization</label>
                    <input asp-for="Polarization" class="form-control" />
                    <span asp-validation-for="Polarization" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Connector" class="control-label">Connector</label>
                    <input asp-for="Connector" class="form-control" />
                    <span asp-validation-for="Connector" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="GainDbi" class="control-label">Gain (dBi)</label>
                    <input asp-for="GainDbi" class="form-control" type="number" step="0.1" />
                    <span asp-validation-for="GainDbi" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="AxialRatio" class="control-label">Axial Ratio</label>
                    <input asp-for="AxialRatio" class="form-control" />
                    <span asp-validation-for="AxialRatio" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="RadiationPattern" class="control-label">Radiation Pattern</label>
                    <input asp-for="RadiationPattern" class="form-control" />
                    <span asp-validation-for="RadiationPattern" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="OperatingFrequencyGhz" class="control-label">Operating Frequency (GHz)</label>
                    <input asp-for="OperatingFrequencyGhz" class="form-control" type="number" step="0.1" />
                    <span asp-validation-for="OperatingFrequencyGhz" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="WeightG" class="control-label">Weight (g)</label>
                    <input asp-for="WeightG" class="form-control" type="number" step="0.1" />
                    <span asp-validation-for="WeightG" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Price" class="control-label">Price ($)</label>
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

            </div>

            <div style="margin-top: 24px; display: flex; gap: 12px;">
                <input type="submit" value="Create" class="button small" />
                <a asp-action="Index" class="button small">Cancel</a>
            </div>

        </form>

    </div>

</body>
</html>