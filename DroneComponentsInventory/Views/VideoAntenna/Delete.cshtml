@model DroneComponentsInventory.Models.VideoAntennaComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete Video Antenna</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/videoantennas.css" />
</head>
<body class="is-preload">

    <div class="videoantennas-panel">

        <h3 style="margin-top: 0;">
            Delete Video Antenna
        </h3>

        <p>
            Are you sure you want to delete this video antenna?
            <strong>This action cannot be undone.</strong>
        </p>

        <hr />

        <dl class="videoantennas-meta">

            <dt>Manufacturer</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Model</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Antenna Class</dt>
            <dd>@Html.DisplayFor(m => m.AntennaClass)</dd>

            <dt>Polarization</dt>
            <dd>@Html.DisplayFor(m => m.Polarization)</dd>

            <dt>Connector</dt>
            <dd>@Html.DisplayFor(m => m.Connector)</dd>

            <dt>Gain (dBi)</dt>
            <dd>@Html.DisplayFor(m => m.GainDbi)</dd>

            <dt>Axial Ratio</dt>
            <dd>@Html.DisplayFor(m => m.AxialRatio)</dd>

            <dt>Radiation Pattern</dt>
            <dd>@Html.DisplayFor(m => m.RadiationPattern)</dd>

            <dt>Operating Frequency (GHz)</dt>
            <dd>@Html.DisplayFor(m => m.OperatingFrequencyGhz)</dd>

            <dt>Weight (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="AntennaId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Cancel
                </a>

                <input type="submit"
                       value="Delete"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>