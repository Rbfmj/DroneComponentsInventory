@model DroneComponentsInventory.Models.VideoAntennaComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Dzēst video antenu</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/videoantennas.css" />
</head>
<body class="is-preload">

    <div class="videoantennas-panel">

        <h3 style="margin-top: 0;">
            Dzēst video antenu
        </h3>

        <p>
            Vai tiešām vēlaties dzēst šo video antenu?
            <strong>Šo darbību nevar atsaukt.</strong>
        </p>

        <hr />

        <dl class="videoantennas-meta">

            <dt>Ražotājs</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Modelis</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Antenna klase</dt>
            <dd>@Html.DisplayFor(m => m.AntennaClass)</dd>

            <dt>Polarizācija</dt>
            <dd>@Html.DisplayFor(m => m.Polarization)</dd>

            <dt>Konektors</dt>
            <dd>@Html.DisplayFor(m => m.Connector)</dd>

            <dt>Ieplūdes jauda (dBi)</dt>
            <dd>@Html.DisplayFor(m => m.GainDbi)</dd>

            <dt>Asimetriskā attiecība</dt>
            <dd>@Html.DisplayFor(m => m.AxialRatio)</dd>

            <dt>Starojuma raksts</dt>
            <dd>@Html.DisplayFor(m => m.RadiationPattern)</dd>

            <dt>Darba frekvence (GHz)</dt>
            <dd>@Html.DisplayFor(m => m.OperatingFrequencyGhz)</dd>

            <dt>Svars (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Cena</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="AntennaId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Atcelt
                </a>

                <input type="submit"
                       value="Dzēst"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>