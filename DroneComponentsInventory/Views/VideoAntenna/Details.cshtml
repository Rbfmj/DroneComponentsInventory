@model DroneComponentsInventory.Models.VideoAntennaComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Video Antenna Details</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/videoantennas.css" />
</head>

<body class="is-preload">

    <div class="videoantennas-panel">

        <h2>@Model.Manufacturer @Model.Model</h2>

        <dl class="videoantennas-meta">
            <dt>Antenna Class</dt>
            <dd>@(Model.AntennaClass ?? "—")</dd>

            <dt>Polarization</dt>
            <dd>@(Model.Polarization ?? "—")</dd>

            <dt>Connector</dt>
            <dd>@(Model.Connector ?? "—")</dd>

            <dt>Gain</dt>
            <dd>@(Model.GainDbi?.ToString() + " dBi" ?? "—")</dd>

            <dt>Axial Ratio</dt>
            <dd>@(Model.AxialRatio?.ToString() ?? "—")</dd>

            <dt>Radiation Pattern</dt>
            <dd>@(Model.RadiationPattern ?? "—")</dd>

            <dt>Operating Frequency</dt>
            <dd>@(Model.OperatingFrequencyGhz?.ToString("0.0") + " GHz" ?? "—")</dd>

            <dt>Weight</dt>
            <dd>@(Model.WeightG?.ToString() + " g" ?? "—")</dd>

            <dt>Price</dt>
            <dd>@(Model.Price.HasValue ? "$" + Model.Price.Value.ToString("0.00") : "—")</dd>
        </dl>

        
        <!-- =====================================================
             ACTION BUTTONS (your new style)
             ===================================================== -->
        <div style="margin-top: 12px; display: flex; gap: 8px;">

            <a asp-action="Edit"
                   asp-route-id="@Model?.AntennaId"
                   class="button small">
                Edit
            </a>

            <a asp-action="Delete"
                   asp-route-id="@Model?.AntennaId"
                   class="button small">
                Delete
            </a>

            <a asp-action="Index"
                   class="button small">
                Back to List
            </a>

        </div>

    </div>

</body>
</html>