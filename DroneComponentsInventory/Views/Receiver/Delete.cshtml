@model DroneComponentsInventory.Models.ReceiverComponent

@{
    /* Standalone view – no shared layout */
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Delete Receiver</title>

    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/receivers.css" />
</head>
<body class="is-preload">

    <div class="receivers-panel">

        <h3 style="margin-top: 0;">
            Delete Receiver
        </h3>

        <p>
            Are you sure you want to delete this receiver?
            <strong>This action cannot be undone.</strong>
        </p>

        <hr />

        <dl class="receivers-meta">

            <dt>Manufacturer</dt>
            <dd>@Html.DisplayFor(m => m.Manufacturer)</dd>

            <dt>Model</dt>
            <dd>@Html.DisplayFor(m => m.Model)</dd>

            <dt>Protocol</dt>
            <dd>@Html.DisplayFor(m => m.Protocol)</dd>

            <dt>Modulation</dt>
            <dd>@Html.DisplayFor(m => m.ModulationProtocol)</dd>

            <dt>Frequency Band</dt>
            <dd>@Html.DisplayFor(m => m.FrequencyBand)</dd>

            <dt>Channels</dt>
            <dd>@Html.DisplayFor(m => m.Channels)</dd>

            <dt>Telemetry Support</dt>
            <dd>@(Model.TelemetrySupport ? "Yes" : "No")</dd>

            <dt>Antenna Count</dt>
            <dd>@Html.DisplayFor(m => m.AntennaCount)</dd>

            <dt>Antenna Type</dt>
            <dd>@Html.DisplayFor(m => m.AntennaType)</dd>

            <dt>Range (km)</dt>
            <dd>@Html.DisplayFor(m => m.RangeKm)</dd>

            <dt>Voltage Input (V)</dt>
            <dd>@Html.DisplayFor(m => m.VoltageInputV)</dd>

            <dt>Output Signal</dt>
            <dd>@Html.DisplayFor(m => m.OutputSignal)</dd>

            <dt>Weight (g)</dt>
            <dd>@Html.DisplayFor(m => m.WeightG)</dd>

            <dt>Length</dt>
            <dd>@Html.DisplayFor(m => m.LengthMm)</dd>

            <dt>Width</dt>
            <dd>@Html.DisplayFor(m => m.WidthMm)</dd>

            <dt>Height</dt>
            <dd>@Html.DisplayFor(m => m.HeightMm)</dd>

            <dt>Mounting</dt>
            <dd>@Html.DisplayFor(m => m.MountingType)</dd>

            <dt>Price</dt>
            <dd>@Html.DisplayFor(m => m.Price)</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden"
                   asp-for="ReceiverId" />

            <div style="
                margin-top: 16px;
                display: flex;
                gap: 12px;
                justify-content: flex-end;">

                <a asp-action="Index"
                       class="button small">
                    Cancel
                </a>

                <input type="submit"
                       value="Delete"
                       class="button small danger" />

            </div>

        </form>

    </div>
</body>
</html>