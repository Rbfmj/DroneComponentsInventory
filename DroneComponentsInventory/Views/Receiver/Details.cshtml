@model DroneComponentsInventory.Models.ReceiverComponent

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="lv">
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Uztvērēja detaļas</title>
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/receivers.css" />
</head>
<body class="is-preload">
    <div class="receivers-panel">
        <h2>@Model.Manufacturer @Model.Model</h2>
        <dl class="receivers-meta">
            <dt>Protokols</dt>
            <dd>@(Model.Protocol ?? "—")</dd>

            <dt>Modulācija</dt>
            <dd>@(Model.ModulationProtocol ?? "—")</dd>

            <dt>Frekvenču josla</dt>
            <dd>@(Model.FrequencyBand ?? "—")</dd>

            <dt>Kanāli</dt>
            <dd>@(Model.Channels?.ToString() ?? "—")</dd>

            <dt>Telemetrijas atbalsts</dt>
            <dd>@(Model.TelemetrySupport ? "Jā" : "Nē")</dd>

            <dt>Antenu skaits</dt>
            <dd>@(Model.AntennaCount?.ToString() ?? "—")</dd>

            <dt>Antenu tips</dt>
            <dd>@(Model.AntennaType ?? "—")</dd>

            <dt>Diapazons</dt>
            <dd>@(Model.RangeKm?.ToString() + " km" ?? "—")</dd>

            <dt>Sprieguma ieeja</dt>
            <dd>@(Model.VoltageInputV?.ToString() + " V" ?? "—")</dd>

            <dt>Izvades signāls</dt>
            <dd>@(Model.OutputSignal ?? "—")</dd>

            <dt>Atslāpšanas atbalsts</dt>
            <dd>@(Model.FailsafeSupport ? "Jā" : "Nē")</dd>

            <dt>Saistīšanas metode</dt>
            <dd>@(Model.BindingMethod ?? "—")</dd>

            <dt>Izmantošanas mērķis</dt>
            <dd>@(Model.IntendedUse ?? "—")</dd>

            <dt>Svars</dt>
            <dd>@(Model.WeightG?.ToString() + " g" ?? "—")</dd>

            <dt>Garums</dt>
            <dd>@(Model.LengthMm?.ToString() + " mm" ?? "—")</dd>

            <dt>Platums</dt>
            <dd>@(Model.WidthMm?.ToString() + " mm" ?? "—")</dd>

            <dt>Augstums</dt>
            <dd>@(Model.HeightMm?.ToString() + " mm" ?? "—")</dd>

            <dt>Montāžas tips</dt>
            <dd>@(Model.MountingType ?? "—")</dd>

            <dt>Cena</dt>
            <dd>@(Model.Price.HasValue ? "$" + Model.Price.Value.ToString("0.00") : "—")</dd>
        </dl>

        
        <!-- =====================================================
             ACTION BUTTONS
             ===================================================== -->
        <div style="margin-top: 12px; display: flex; gap: 8px;">

            <a asp-action="Edit"
                   asp-route-id="@Model?.ReceiverId"
                   class="button small">
                Rediģēt
            </a>

            <a asp-action="Delete"
                   asp-route-id="@Model?.ReceiverId"
                   class="button small">
                Dzēst
            </a>

            <a asp-action="Index"
                   class="button small">
                Atpakaļ uz sarakstu
            </a>

        </div>

    </div>

</body>
</html>