@model IEnumerable<DroneComponentsInventory.Models.ReceiverComponent>
@using System.Linq

@{
    /* This view is rendered standalone (no shared layout) */
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Basic responsive meta -->
    <meta name="viewport" content="width=device-width" />

    <title>FPV Receivers</title>

    <!-- Core site styles -->
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/receivers.css" />
</head>

<body class="is-preload">

    <div class="receivers-view">

        <div class="wrapper style1 align-center">
            <div class="inner">
                <h2>FPV Receivers</h2>

                <p>Select a receiver to view technical specifications.</p>

                <p>
                    <a asp-action="Create" class="button small">Add New Receiver</a>
                </p>
            </div>
        </div>

        <div class="wrapper">
            <div class="inner">

                <div class="receivers-grid" id="receiversGrid">

                    @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.ReceiverComponent>())
                    {
                        <article class="receivers-tile" data-modal-id="rxmodal-@item.ReceiverId">
                            <div>
                                <span class="title">@item.Manufacturer</span>
                                <span class="muted">@item.Model</span>
                            </div>
                        </article>
                    }

                </div>

            </div>
        </div>

        @foreach (var item in Model ?? Enumerable.Empty<DroneComponentsInventory.Models.ReceiverComponent>())
        {
            <div id="rxmodal-@item.ReceiverId" class="receivers-modal" style="display:none;" aria-hidden="true">
                <div class="panel">

                    <button type="button" class="button small close-modal" style="position:absolute; right:12px; top:12px;">×</button>

                    <h2>@item.Manufacturer @item.Model</h2>

                    <dl class="receivers-meta">
                        <dt>Protocol</dt>
                        <dd>@item.Protocol</dd>

                        <dt>Modulation</dt>
                        <dd>@item.ModulationProtocol</dd>

                        <dt>Frequency Band</dt>
                        <dd>@item.FrequencyBand</dd>

                        <dt>Channels</dt>
                        <dd>@item.Channels</dd>

                        <dt>Telemetry Support</dt>
                        <dd>@(item.TelemetrySupport ? "Yes" : "No")</dd>

                        <dt>Antenna Count</dt>
                        <dd>@item.AntennaCount</dd>

                        <dt>Antenna Type</dt>
                        <dd>@item.AntennaType</dd>

                        <dt>Range</dt>
                        <dd>@(item.RangeKm?.ToString() + " km" ?? "")</dd>

                        <dt>Voltage Input</dt>
                        <dd>@(item.VoltageInputV?.ToString() + " V" ?? "")</dd>

                        <dt>Output Signal</dt>
                        <dd>@item.OutputSignal</dd>

                        <dt>Failsafe Support</dt>
                        <dd>@(item.FailsafeSupport ? "Yes" : "No")</dd>

                        <dt>Binding Method</dt>
                        <dd>@item.BindingMethod</dd>

                        <dt>Intended Use</dt>
                        <dd>@item.IntendedUse</dd>

                        <dt>Weight</dt>
                        <dd>@(item.WeightG?.ToString() + " g" ?? "")</dd>

                        <dt>Length</dt>
                        <dd>@(item.LengthMm?.ToString() + " mm" ?? "")</dd>

                        <dt>Width</dt>
                        <dd>@(item.WidthMm?.ToString() + " mm" ?? "")</dd>

                        <dt>Height</dt>
                        <dd>@(item.HeightMm?.ToString() + " mm" ?? "")</dd>

                        <dt>Mounting Type</dt>
                        <dd>@item.MountingType</dd>

                        <dt>Price</dt>
                        <dd>@(item.Price.HasValue? item.Price.Value.ToString("0.00") : "")</dd>
                    </dl>

                    <div style="margin-top:16px; display:flex; gap:12px; justify-content:flex-end;">
                        <a class="button small" asp-action="Edit" asp-route-id="@item.ReceiverId">Edit</a>
                        <a class="button small" asp-action="Details" asp-route-id="@item.ReceiverId">Details</a>
                        <a class="button small danger" asp-action="Delete" asp-route-id="@item.ReceiverId">Delete</a>
                        <button type="button" class="button small close-modal">Close</button>
                    </div>

                </div>
            </div>
        }

    </div>

    <script src="/js/receivers-modals.js"></script>

</body>
</html>