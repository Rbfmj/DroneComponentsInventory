                <span asp-validation-for="LengthMm" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="WidthMm" class="control-label"></label>
                <input asp-for="WidthMm" class="form-control" />
                <span asp-validation-for="WidthMm" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="HeightMm" class="control-label"></label>
                <input asp-for="HeightMm" class="form-control" />
                <span asp-validation-for="HeightMm" class="text-danger"></span>
