                <input asp-for="VoltageInputV" class="form-control" />
                <span asp-validation-for="VoltageInputV" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="OutputSignal" class="control-label"></label>
                <input asp-for="OutputSignal" class="form-control" />
                <span asp-validation-for="OutputSignal" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="FailsafeSupport" /> @Html.DisplayNameFor(model => model.FailsafeSupport)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="BindingMethod" class="control-label"></label>
                <input asp-for="BindingMethod" class="form-control" />
                <span asp-validation-for="BindingMethod" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IntendedUse" class="control-label"></label>
                <input asp-for="IntendedUse" class="form-control" />
                <span asp-validation-for="IntendedUse" class="text-danger"></span>
            </div>
