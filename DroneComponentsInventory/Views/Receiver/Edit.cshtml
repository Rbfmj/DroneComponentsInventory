@model DroneComponentsInventory.Models.ReceiverComponent

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Edit</title>
</head>
<body>

<h4>ReceiverComponent</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ReceiverId" />
            <div class="form-group">
                <label asp-for="Manufacturer" class="control-label"></label>
                <input asp-for="Manufacturer" class="form-control" />
                <span asp-validation-for="Manufacturer" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Model" class="control-label"></label>
                <input asp-for="Model" class="form-control" />
                <span asp-validation-for="Model" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Protocol" class="control-label"></label>
                <input asp-for="Protocol" class="form-control" />
                <span asp-validation-for="Protocol" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ModulationProtocol" class="control-label"></label>
                <input asp-for="ModulationProtocol" class="form-control" />
                <span asp-validation-for="ModulationProtocol" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FrequencyBand" class="control-label"></label>
                <input asp-for="FrequencyBand" class="form-control" />
                <span asp-validation-for="FrequencyBand" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Channels" class="control-label"></label>
                <input asp-for="Channels" class="form-control" />
                <span asp-validation-for="Channels" class="text-danger"></span>
            </div>
            <div class="form-group form-check">
                <label class="form-check-label">
                    <input class="form-check-input" asp-for="TelemetrySupport" /> @Html.DisplayNameFor(model => model.TelemetrySupport)
                </label>
            </div>
            <div class="form-group">
                <label asp-for="AntennaCount" class="control-label"></label>
                <input asp-for="AntennaCount" class="form-control" />
                <span asp-validation-for="AntennaCount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="AntennaType" class="control-label"></label>
                <input asp-for="AntennaType" class="form-control" />
